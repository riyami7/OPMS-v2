@model OperationalPlanMS.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "_LoginLayout";
}

<div class="login-card">
    <!-- Logo & Brand -->
    <div class="logo-section">
        <div class="logo-wrap">
            <img src="~/img/logo.png" alt="Logo" />
        </div>
        <h1 class="sys-name">نظام إدارة الخطط التشغيلية</h1>
        <p class="sys-name-en">Operational Plan Management System</p>
    </div>

    <div class="divider"></div>

    <!-- Form Header -->
    <div class="form-header">
        <p>أدخل بيانات حسابك للمتابعة</p>
    </div>

    <form asp-action="Login" asp-controller="Account" method="post">
        <input type="hidden" asp-for="ReturnUrl" />

        <!-- Errors -->
        <div asp-validation-summary="ModelOnly" class="err-box" role="alert"></div>

        <!-- Username -->
        <div class="field">
            <label class="field-label" for="username">اسم المستخدم</label>
            <div class="field-control">
                <div class="fc-icon">
                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z" />
                    </svg>
                </div>
                <input asp-for="Username" class="fc-input" id="username"
                       placeholder="أدخل اسم المستخدم" autofocus autocomplete="username" />
            </div>
            <span asp-validation-for="Username" class="field-error"></span>
        </div>

        <!-- Password -->
        <div class="field">
            <label class="field-label" for="password">كلمة المرور</label>
            <div class="field-control">
                <div class="fc-icon">
                    <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2" />
                    </svg>
                </div>
                <input asp-for="Password" class="fc-input" id="password"
                       placeholder="أدخل كلمة المرور" autocomplete="current-password" />
                <button type="button" class="fc-toggle" onclick="togglePwd()" aria-label="إظهار/إخفاء كلمة المرور">
                    <svg id="eyeOn" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                    </svg>
                    <svg id="eyeOff" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" style="display:none">
                        <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z" />
                        <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829" />
                        <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z" />
                    </svg>
                </button>
            </div>
            <span asp-validation-for="Password" class="field-error"></span>
        </div>

        <!-- Remember me -->
        <div class="meta-row">
            <label class="chk-label">
                <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                <span class="chk-box"></span>
                <span class="chk-text">تذكرني</span>
            </label>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-go">
            <span>تسجيل الدخول</span>
            <span class="arrow-wrap">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
                </svg>
            </span>
        </button>
    </form>

    <div class="form-foot">
        <p>&copy; 2026 جميع الحقوق محفوظة &mdash; نظام إدارة الخطط التشغيلية</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd() {
            var inp = document.getElementById('password');
            var on = document.getElementById('eyeOn');
            var off = document.getElementById('eyeOff');
            if (inp.type === 'password') {
                inp.type = 'text'; on.style.display = 'none'; off.style.display = 'block';
            } else {
                inp.type = 'password'; on.style.display = 'block'; off.style.display = 'none';
            }
        }
    </script>
}

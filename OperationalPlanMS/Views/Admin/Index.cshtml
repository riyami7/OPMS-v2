<style>
    /* ---- بطاقة المساعد الذكي ---- */
    .ai-settings-card {
        border: 2px solid var(--bg-sidebar) !important;
        transition: all .3s ease;
    }

        .ai-settings-card:hover {
            box-shadow: 0 8px 32px rgba(15,37,68,.15);
            transform: translateY(-2px);
        }

        .ai-settings-card.ai-settings-card--off {
            border-color: #d1d5db !important;
            opacity: .7;
        }

            .ai-settings-card.ai-settings-card--off .ai-settings-icon {
                background: #e5e7eb;
                color: #9ca3af;
            }

            .ai-settings-card.ai-settings-card--off .ai-settings-glow {
                opacity: 0;
            }

    .ai-settings-glow {
        position: absolute;
        top: -20px;
        left: 50%;
        transform: translateX(-50%);
        width: 100px;
        height: 100px;
        background: radial-gradient(circle, rgba(201,168,76,.12) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
        transition: opacity .4s;
    }

    .ai-settings-icon {
        width: 64px;
        height: 64px;
        margin: 0 auto;
        border-radius: 16px;
        background: linear-gradient(145deg, var(--bg-sidebar), var(--primary));
        color: #c9a84c;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .4s ease;
        position: relative;
        z-index: 1;
    }

        .ai-settings-icon svg {
            width: 32px;
            height: 32px;
        }

    /* ---- Toggle Switch ---- */
    .ai-toggle-wrap {
        margin: 16px 0 4px;
    }

    .ai-toggle {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
    }

    .ai-toggle__track {
        position: relative;
        width: 52px;
        height: 28px;
        border-radius: 14px;
        background: var(--bg-sidebar);
        transition: background .3s ease;
        display: flex;
        align-items: center;
        padding: 0 3px;
    }

    .ai-toggle[aria-checked="false"] .ai-toggle__track {
        background: #d1d5db;
    }

    .ai-toggle__thumb {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #c9a84c;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform .3s cubic-bezier(.4,0,.2,1), background .3s;
        transform: translateX(0);
        box-shadow: 0 1px 4px rgba(0,0,0,.2);
    }

    .ai-toggle[aria-checked="true"] .ai-toggle__thumb {
        transform: translateX(0);
    }

    .ai-toggle[aria-checked="false"] .ai-toggle__thumb {
        transform: translateX(24px);
        background: #fff;
    }

    .ai-toggle__ico {
        width: 12px;
        height: 12px;
    }

    .ai-toggle__ico--on {
        color: var(--bg-sidebar);
    }

    .ai-toggle__ico--off {
        color: #9ca3af;
    }

    .ai-toggle__label {
        font-size: .85rem;
        font-weight: 600;
        color: #1e293b;
        min-width: 48px;
    }

    /* ---- حالة ---- */
    .ai-settings-status {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

        .ai-settings-status small {
            font-size: .76rem;
            color: #64748b;
        }

    .ai-settings-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        transition: background .3s;
    }

    .ai-settings-dot--on {
        background: #22c55e;
    }

    .ai-settings-dot--off {
        background: #d1d5db;
    }
</style>


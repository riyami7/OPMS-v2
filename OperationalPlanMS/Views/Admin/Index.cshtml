@section Scripts {
    <script>
        (function() {
            var card     = document.getElementById('chatbotCard');
            var toggle   = document.getElementById('chatbotToggle');
            var label    = document.getElementById('chatbotLabel');
            var statusEl = document.getElementById('chatbotStatus');
            var icoOn    = toggle.querySelector('.ai-toggle__ico--on');
            var icoOff   = toggle.querySelector('.ai-toggle__ico--off');

            // تحميل الحالة الحالية
            fetch('/Admin/ChatbotStatus')
                .then(function(r) { return r.json(); })
                .then(function(d) { setUI(d.enabled); })
                .catch(function() { setUI(true); });

            // Toggle click
            toggle.addEventListener('click', function() {
                toggle.disabled = true;

                var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                         || document.querySelector('meta[name="csrf-token"]')?.content || '';

                fetch('/Admin/ToggleChatbot', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: '__RequestVerificationToken=' + encodeURIComponent(token)
                })
                .then(function(r) { return r.json(); })
                .then(function(d) { setUI(d.enabled); })
                .catch(function() { })
                .finally(function() { toggle.disabled = false; });
            });

            function setUI(enabled) {
                toggle.setAttribute('aria-checked', enabled ? 'true' : 'false');
                label.textContent = enabled ? 'مفعّل' : 'معطّل';
                icoOn.style.display  = enabled ? '' : 'none';
                icoOff.style.display = enabled ? 'none' : '';
                card.classList.toggle('ai-settings-card--off', !enabled);
                statusEl.innerHTML = enabled
                    ? '<span class="ai-settings-dot ai-settings-dot--on"></span><small>يعمل الآن</small>'
                    : '<span class="ai-settings-dot ai-settings-dot--off"></span><small>معطّل</small>';
            }
        })();
    </script>
}

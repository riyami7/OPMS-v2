@model OperationalPlanMS.Models.ViewModels.FiscalYearListViewModel
@{
    ViewData["Title"] = "إدارة السنوات المالية";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">إدارة السنوات المالية</h4>
        <p class="text-muted mb-0">عرض وإدارة السنوات المالية</p>
    </div>
    <div>
        <a href="/FiscalYears/Create" class="btn btn-warning">
            <i class="bi bi-plus-circle me-2"></i>إضافة سنة مالية
        </a>
        <a href="/Admin" class="btn btn-outline-secondary ms-2">
            <i class="bi bi-arrow-right me-2"></i>رجوع
        </a>
    </div>
</div>

<!-- Filter -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-10">
                    <input type="text" class="form-control" name="searchTerm" placeholder="البحث بالاسم..." />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>بحث
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>السنة</th>
                        <th>الاسم بالعربية</th>
                        <th>الاسم بالإنجليزية</th>
                        <th>الفترة</th>

                        <th>الحالة</th>
                        <th style="width: 180px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.FiscalYears.Any())
                    {
                        @foreach (var item in Model.FiscalYears)
                        {
                            <tr class="@(item.IsCurrent ? "table-warning" : "")">
                                <td><strong>@item.Year</strong></td>
                                <td>@item.NameAr</td>
                                <td dir="ltr" class="text-end">@item.NameEn</td>
                                <td>
                                    <small>@item.StartDate.ToString("yyyy-MM-dd") - @item.EndDate.ToString("yyyy-MM-dd")</small>
                                </td>

                                <td>
                                    @if (item.IsCurrent)
                                    {
                                        <span class="badge bg-warning text-dark">السنة الحالية</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">غير نشط</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/FiscalYears/Edit/@item.Id" class="btn btn-outline-warning" title="تعديل">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (!item.IsCurrent)
                                        {
                                            <form asp-controller="FiscalYears" asp-action="SetCurrent" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-success" title="تعيين كحالية">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-controller="FiscalYears" asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('هل أنت متأكد من الحذف؟');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="حذف">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="bi bi-calendar-range" style="font-size: 2rem;"></i>
                                <p class="mt-2 mb-0">لا توجد سنوات مالية</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model OperationalPlanMS.Models.ViewModels.StrategicOverviewViewModel
@{
    ViewData["Title"] = "الخطة الاستراتيجية";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        /* background: linear-gradient(149deg, #a14695 0%, #2ba2b9 100%); */
        color: white;
        padding: 3rem 2rem;
        border-radius: 20px;
        margin-bottom: 2rem;
        text-align: center;
    }

    .hero-section h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: white;
    }

    .hero-section p {
        opacity: 0.9;
        font-size: 1.1rem;
    }

    .nav-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 992px) {
        .nav-cards { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 576px) {
        .nav-cards { grid-template-columns: 1fr; }
    }

    .nav-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 5px 25px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
        border: 2px solid transparent;
    }

    .nav-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        text-decoration: none;
        color: inherit;
    }

    .nav-card.vision-mission {
        border-top: 5px solid var(--primary);
    }

    .nav-card.vision-mission:hover {
        border-color: var(--primary);
    }

    .nav-card.objectives {
        border-top: 5px solid var(--accent);
    }

    .nav-card.objectives:hover {
        border-color: var(--accent);
    }

    .nav-card.values {
        border-top: 5px solid #8B7355;
    }

    .nav-card.values:hover {
        border-color: #8B7355;
    }

    .nav-card .card-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
    }

    .nav-card.vision-mission .card-icon {
        background: linear-gradient(135deg, #e8f0e5, #d0e5c8);
    }

    .nav-card.objectives .card-icon {
        background: linear-gradient(135deg, #fdf5e6, #f5e6c8);
    }

    .nav-card.values .card-icon {
        background: linear-gradient(135deg, #f0ebe4, #e5ddd2);
    }

    .nav-card .card-icon i {
        font-size: 2.2rem;
    }

    .nav-card.vision-mission .card-icon i { color: var(--primary); }
    .nav-card.objectives .card-icon i { color: var(--accent-dark); }
    .nav-card.values .card-icon i { color: #8B7355; }

    .nav-card h3 {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
    }

    .nav-card p {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 1rem;
    }

    .nav-card .stats {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
    }

    .nav-card .stat {
        text-align: center;
    }

    .nav-card .stat .num {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-dark);
    }

    .nav-card .stat .lbl {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .nav-card .btn-view {
        margin-top: 1rem;
        padding: 0.5rem 1.5rem;
        border-radius: 25px;
        font-size: 0.9rem;
    }

    .nav-card.vision-mission .btn-view {
        background: var(--primary);
        color: white;
        border: none;
    }

    .nav-card.objectives .btn-view {
        background: var(--accent-dark);
        color: white;
        border: none;
    }

    .nav-card.values .btn-view {
        background: #8B7355;
        color: white;
        border: none;
    }

    /* Quick Stats */
    .quick-stats {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .quick-stats h5 {
        font-size: 1rem;
        color: var(--text-muted);
        margin-bottom: 1rem;
        text-align: center;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
    }

    @@media (max-width: 768px) {
        .stats-grid { grid-template-columns: repeat(3, 1fr); }
    }

    .stat-item {
        text-align: center;
        padding: 1rem;
        background: white;
        border-radius: 12px;
    }

    .stat-item .number {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--primary);
    }

    .stat-item .label {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 0.25rem;
    }

    .logo{
        width: 300px;
        height:300px;
    }
</style>


                        </div>
                        @*   <div class="col-md-6">
                            <label asp-for="NameEn" class="form-label"></label>
                            <input asp-for="NameEn" class="form-control" placeholder="Enter initiative name in English" dir="ltr" />
                            <span asp-validation-for="NameEn" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DescriptionAr" class="form-label"></label>
                            <textarea asp-for="DescriptionAr" class="form-control" rows="3" placeholder="وصف المديرية بالعربية"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DescriptionEn" class="form-label"></label>
                            <textarea asp-for="DescriptionEn" class="form-control" rows="3" placeholder="Initiative description in English" dir="ltr"></textarea>
                        </div> *@
                        @*  <div class="col-12">
                            <label asp-for="StrategicObjective" class="form-label"></label>
                            <input asp-for="StrategicObjective" class="form-control" placeholder="الهدف الاستراتيجي المرتبط بالمبادرة" />
                        </div> *@

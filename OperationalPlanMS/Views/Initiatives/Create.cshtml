                </div>
            </div>
            @* 
            <!-- Dates -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-calendar me-2"></i>التواريخ الفعلية
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ActualStartDate" class="form-label"></label>
                            <input asp-for="ActualStartDate" type="date" class="form-control" />

@model OperationalPlanMS.Models.ViewModels.InitiativeListViewModel
@{
    ViewData["Title"] = "الوحدات التنظيمية";
    var canEdit = (bool)(ViewBag.CanEdit ?? false);
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-title">
        <h4><i class="bi bi-lightning-charge me-2 text-warning"></i>الوحدات التنظيمية</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">الرئيسية</a></li>
                <li class="breadcrumb-item active">الوحدات التنظيمية</li>
            </ol>
        </nav>
    </div>
    @if (canEdit)
    {
        <div class="page-header-actions">
            <a href="/Initiatives/Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>إضافة
            </a>
        </div>
    }
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel"></i>فلاتر البحث
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">البحث</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" asp-for="SearchTerm" placeholder="اسم الوحدة ..." />
                    </div>
                </div>
                @*   <div class="col-md-2">
                    <label class="form-label">السنة المالية</label>
                    <select class="form-select" asp-for="FiscalYearId" asp-items="Model.FiscalYears">
                        <option value="">-- الكل --</option>
                    </select>
                </div> *@
                <div class="col-md-4">
                    <label class="form-label">الوحدة التنظيمية</label>
                    <div id="filterOrgTree"></div>
                </div>
                <input type="hidden" id="ExternalUnitId" name="ExternalUnitId" value="@ViewBag.ExternalUnitId" />
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary "><i class="bi bi-search"></i>بحث</button>
                    <a href="/Initiatives" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i>إعادة تعيين</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Results Info -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted small">
        <i class="bi bi-list-ul me-1"></i>عرض <strong>@Model.Initiatives.Count</strong> من <strong>@Model.TotalCount</strong> نتيجة
    </span>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        @* <th style="width:100px;">الكود</th> *@
                        @* <th>المديرية</th> *@
                        <th>الوحدة التنظيمية</th>
                        <th>المدير</th>
                        <th style="width:90px;" class="text-center">المشاريع</th>
                        @* <th style="width:150px;">التواريخ</th> *@
                        <th style="width:100px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Initiatives.Any())
                    {
                        @foreach (var item in Model.Initiatives)
                        {
                            var projectsCount = item.Projects?.Count(p => !p.IsDeleted) ?? 0;
                            var unitName = item.ExternalUnitName ?? "-";
                            var supervisorName = !string.IsNullOrEmpty(item.SupervisorName) ? item.SupervisorName : item.Supervisor?.FullNameAr ?? "-";
                            var supervisorRank = item.SupervisorRank ?? "";
                            var supervisorEmpNumber = item.SupervisorEmpNumber ?? "";
                            var supervisorEmployeePosition = item.Supervisor?.EmployeePosition ?? "";

                            <tr>
                                @* <td><code class="text-primary fw-bold">@item.Code</code></td> *@

                                <td>
                                    <a href="/Initiatives/Details/@item.Id" class="fw-bold text-decoration-none text-dark">  <span><i class="bi bi-building me-1 text-muted"></i>@unitName</span></a>
                                </td>
                                <td>
                                    <div class="d-flex align-items-start gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                             style="width:30px;height:30px;background:var(--info-light);">
                                            <i class="bi bi-person" style="color:var(--info);font-size:.75rem;"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold" style="font-size:.85rem;">@supervisorRank @supervisorName</div>
                                            @if (!string.IsNullOrEmpty(item.Supervisor?.EmployeePosition))
                                            {
                                                <small class="text-muted d-block">@item.Supervisor?.EmployeePosition</small>
                                            }

                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill" style="background:var(--info-light);color:var(--info);">@projectsCount</span>
                                </td>
                                @*   <td>
                                    @if (item.ActualStartDate.HasValue)
                                    {
                                        <small class="text-muted d-block"><i class="bi bi-calendar-event me-1"></i>@item.ActualStartDate.Value.ToString("yyyy-MM-dd")</small>
                                    }
                                    @if (item.ActualEndDate.HasValue)
                                    {
                                        <small class="text-muted d-block"><i class="bi bi-calendar-check me-1"></i>@item.ActualEndDate.Value.ToString("yyyy-MM-dd")</small>
                                    }
                                    @if (!item.ActualStartDate.HasValue && !item.ActualEndDate.HasValue)
                                    {
                                        <small class="text-muted">-</small>
                                    }
                                </td> *@
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/Initiatives/Details/@item.Id" class="btn btn-sm btn-outline-primary" title="عرض"><i class="bi bi-eye"></i></a>
                                        @if (canEdit)
                                        {
                                            <a href="/Initiatives/Edit/@item.Id" class="btn btn-sm btn-outline-warning" title="تعديل"><i class="bi bi-pencil"></i></a>
                                            <a href="/Initiatives/Delete/@item.Id" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="bi bi-lightning-charge text-muted" style="font-size:3rem;opacity:.3;"></i>
                                <h6 class="mt-3 text-muted fw-normal">لا توجد وحدات تنظيمية</h6>
                                <p class="text-muted small mb-3">لم يتم العثور على نتائج مطابقة للفلتر</p>
                                @if (canEdit)
                                {
                                    <a href="/Initiatives/Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>إضافة وحدة تنظيمية جديدة</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?CurrentPage=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm&FiscalYearId=@Model.FiscalYearId&ExternalUnitId=@ViewBag.ExternalUnitId"><i class="bi bi-chevron-right"></i></a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?CurrentPage=@i&SearchTerm=@Model.SearchTerm&FiscalYearId=@Model.FiscalYearId&ExternalUnitId=@ViewBag.ExternalUnitId">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?CurrentPage=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm&FiscalYearId=@Model.FiscalYearId&ExternalUnitId=@ViewBag.ExternalUnitId"><i class="bi bi-chevron-left"></i></a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            OrgTreePicker.init({
                containerId: 'filterOrgTree',
                hiddenInputId: 'ExternalUnitId',
                selectedId: '@(ViewBag.ExternalUnitId ?? "")',
                 rootCode: '00001'

            });
        });
    </script>
}

@model OperationalPlanMS.Models.ViewModels.EditProfileViewModel
@{
    ViewData["Title"] = "تعديل البيانات الشخصية";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">تعديل البيانات الشخصية</h4>
        <p class="text-muted mb-0">تحديث معلوماتك الشخصية</p>
    </div>
    <a href="/Profile" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع للملف الشخصي
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil-square me-2"></i>البيانات الشخصية
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="FullNameAr" class="form-label"></label>
                        <input asp-for="FullNameAr" class="form-control" placeholder="الاسم الكامل بالعربية" />
                        <span asp-validation-for="FullNameAr" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="FullNameEn" class="form-label"></label>
                        <input asp-for="FullNameEn" class="form-control" dir="ltr" placeholder="Full Name in English" />
                        <span asp-validation-for="FullNameEn" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" dir="ltr" placeholder="example@email.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>حفظ التغييرات
                        </button>
                        <a href="/Profile" class="btn btn-outline-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

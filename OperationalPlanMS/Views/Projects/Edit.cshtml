@model OperationalPlanMS.Models.ViewModels.ProjectFormViewModel
@{
    ViewData["Title"] = "تعديل الهدف التشغيلي";
}

<div class="container-fluid">
    <div class="page-header">
        <div class="page-header-title">
            <h4 class="mb-1"><i class="bi bi-pencil me-2 text-warning"></i>@ViewData["Title"]</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">الرئيسية</a></li>
                    <li class="breadcrumb-item"><a href="/Projects">الأهداف التشغيلية</a></li>
                    <li class="breadcrumb-item"><i class="bi bi-lightning-charge me-1 text-warning"></i>@ViewBag.InitiativeName</li>
                    <li class="breadcrumb-item active"><span class="badge badge-draft">@Model.Code</span></li>
                </ol>
            </nav>
        </div>
        <div class="page-header-actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                <i class="bi bi-eye"></i>عرض
            </a>
            <a asp-action="Details" asp-controller="Initiatives" asp-route-id="@Model.InitiativeId" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-right"></i>رجوع
            </a>
        </div>
    </div>

    @if (ViewBag.CalculatedProgress != null)
    {
        <div class="progress-info">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>نسبة الإنجاز الحالية</h6>
                    <small>محسوبة من الخطوات التنفيذية المكتملة</small>
                </div>
                <div class="text-end">
                    <h3 class="mb-0">@ViewBag.CalculatedProgress%</h3>
                </div>
            </div>
        </div>
    }

    <form asp-action="Edit" method="post" id="projectForm">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="InitiativeId" />

        <div class="row">
            <div class="col-lg-8">
                <partial name="Partials/ProjectForm/_ProjectForm_BasicInfo" model="Model" />
                <partial name="Partials/ProjectForm/_ProjectForm_OrgStructure" model="Model" />
                <partial name="Partials/ProjectForm/_ProjectForm_SupportingEntities" model="Model" />
                <partial name="Partials/ProjectForm/_ProjectForm_RequirementsKPIs" model="Model" />
            </div>
            <div class="col-lg-4">
                <partial name="Partials/ProjectForm/_ProjectForm_Sidebar" model="Model" />
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.ProjectFormConfig = {
            requirementIndex: @(Model.Requirements?.Count ?? 0),
            kpiIndex: @(Model.KPIItems?.Count ?? 0),
            supportingEntities: @Html.Raw(Json.Serialize(Model.SupportingEntitiesWithReps ?? new List<OperationalPlanMS.Models.ViewModels.SupportingEntityWithRepViewModel>())),
            existingYearTargets: @Html.Raw(Json.Serialize(Model.YearTargets ?? new List<OperationalPlanMS.Models.ViewModels.YearTargetItemViewModel>())),
            savedExternalUnitId: '@(Model.ExternalUnitId?.ToString() ?? "")',
            savedSubObjectiveIds: @Html.Raw(Json.Serialize(Model.SubObjectiveIds ?? new List<int>()))
        };
    </script>
    <script src="~/js/project-form.js"></script>
}

@model OperationalPlanMS.Models.ViewModels.ReportsDashboardViewModel
@{
    ViewData["Title"] = "لوحة المتابعة التنفيذية";

    // مؤشر الصحة — مبني على المشاريع المتأخرة فقط (بدون عد مزدوج)
    var healthScore = Model.TotalProjects > 0
        ? (int)Math.Round((1 - ((decimal)Model.DelayedProjects / Model.TotalProjects)) * 100)
        : 100;
    healthScore = Math.Max(0, Math.Min(100, healthScore));
    var healthColor = healthScore >= 80 ? "#0e7d5a" : healthScore >= 60 ? "#b45309" : "#b91c1c";
    var healthStatus = healthScore >= 80 ? "ممتاز" : healthScore >= 60 ? "يحتاج متابعة" : "يحتاج تدخل";
    double gaugeCircumference = Math.PI * 70;
    double gaugeDashOffset = gaugeCircumference * (1 - healthScore / 100.0);

    // مؤشر الكفاءة
    var effColor = Model.TimeEfficiencyIndex >= 90 ? "#0e7d5a"
                 : Model.TimeEfficiencyIndex >= 70 ? "#b45309" : "#b91c1c";
    var effLabel = Model.TimeEfficiencyIndex >= 90 ? "ممتاز"
                 : Model.TimeEfficiencyIndex >= 70 ? "مقبول" : "ضعيف";
}

<!-- HEADER -->
<div class="rpt-header mb-4">
    <div class="row align-items-center g-3">
        <div class="col-lg-5">
            <h4 class="mb-1 text-white fw-bold">
                <i class="bi bi-speedometer2 me-2"></i>لوحة المتابعة التنفيذية
            </h4>
            <p class="mb-0 text-white-50 small">
                <span>@DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ar-OM"))</span>
                @if (!string.IsNullOrEmpty(Model.SelectedUnitName))
                {
                    <span class="mx-2 opacity-50">|</span>
                    <span class="badge bg-white bg-opacity-20 text-white">
                        <i class="bi bi-building me-1"></i>@Model.SelectedUnitName
                    </span>
                }
            </p>
        </div>
        <div class="col-lg-5">
            <div class="row g-2 text-white text-center">
                <div class="col-3">
                    <div class="rpt-qk">
                        <div class="rpt-qk-v">@Model.TotalInitiatives</div>
                        <div class="rpt-qk-l">وحدة تنظيمية</div>
                    </div>
                </div>
                <div class="col-3">
                    <div class="rpt-qk">
                        <div class="rpt-qk-v">@Model.TotalProjects</div>
                        <div class="rpt-qk-l">هدف تشغيلي</div>
                    </div>
                </div>
                <div class="col-3">
                    <div class="rpt-qk">
                        <div class="rpt-qk-v">@Model.TotalSteps</div>
                        <div class="rpt-qk-l">خطوة تنفيذية</div>
                    </div>
                </div>
                <div class="col-3">
                    @if (Model.DelayedProjects > 0)
                    {
                        <div class="rpt-qk rpt-qk-danger">
                            <div class="rpt-qk-v">@Model.DelayedProjects</div>
                            <div class="rpt-qk-l">هدف تشغيلي متأخر</div>
                        </div>
                    }
                    else
                    {
                        <div class="rpt-qk">
                            <div class="rpt-qk-v">0</div>
                            <div class="rpt-qk-l">متأخر</div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-2 text-center">
            <div class="d-flex align-items-center justify-content-center gap-3">
                <div>
                    <svg viewBox="0 0 180 110" width="100" height="62">
                        <path d="M 20 90 A 70 70 0 0 1 160 90"
                              fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="13" stroke-linecap="round" />
                        <path d="M 20 90 A 70 70 0 0 1 160 90"
                              fill="none" stroke="@healthColor" stroke-width="13" stroke-linecap="round"
                              stroke-dasharray="@gaugeCircumference.ToString("F1")"
                              stroke-dashoffset="@gaugeDashOffset.ToString("F1")" />
                        <text x="90" y="84" text-anchor="middle" font-size="22" font-weight="800"
                              fill="white" font-family="AlQabas">@healthScore%</text>
                        <text x="90" y="99" text-anchor="middle" font-size="9"
                              fill="rgba(255,255,255,0.65)" font-family="AlQabas">@healthStatus</text>
                    </svg>
                    <div style="font-size:.68rem;color:rgba(255,255,255,.5);margin-top:-4px;">صحة الخطة</div>
                </div>
                <div class="dropdown">
                    <button class="btn btn-sm" style="background:rgba(255,255,255,.15);color:white;border:1px solid rgba(255,255,255,.2);"
                            data-bs-toggle="dropdown">
                        <i class="bi bi-download"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Reports/Export?type=initiatives&externalUnitId=@Model.ExternalUnitId"><i class="bi bi-lightning-charge me-2 text-warning"></i>المبادرات</a></li>
                        <li><a class="dropdown-item" href="/Reports/Export?type=projects&externalUnitId=@Model.ExternalUnitId"><i class="bi bi-folder me-2 text-success"></i>المشاريع</a></li>
                        <li><a class="dropdown-item" href="/Reports/Export?type=steps&externalUnitId=@Model.ExternalUnitId"><i class="bi bi-list-check me-2 text-info"></i>الخطوات</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/Reports/Export?type=overdue&externalUnitId=@Model.ExternalUnitId"><i class="bi bi-exclamation-triangle me-2"></i>المتأخرات</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FILTER — الوحدة التنظيمية فقط -->
<div class="card mb-4">
    <div class="card-header" data-bs-toggle="collapse" data-bs-target="#filterSection" style="cursor:default;">
        <div class="d-flex justify-content-between align-items-center">
            <span><i class="bi bi-funnel me-2"></i><strong>فلتر الوحدة التنظيمية</strong></span>
             
        </div>
    </div>
    <div  id="filterSection">
        <div class="card-body">
            <form method="get" asp-action="Index" id="filterForm">
                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        <label class="form-label"><i class="bi bi-building me-1 text-primary"></i>الوحدة التنظيمية</label>
                        <div id="filterOrgTree"></div>
                    </div>
                    <div class="col-md-4">
                        <div id="selectedUnitDisplay" class="mb-2">
                            @if (!string.IsNullOrEmpty(Model.SelectedUnitName))
                            {
                                <span class="badge badge-approved" style="font-size:.82rem;padding:6px 12px;">
                                    <i class="bi bi-building me-1"></i>@Model.SelectedUnitName
                                </span>
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-funnel"></i> تطبيق</button>
                            <a href="/Reports" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> إعادة</a>
                        </div>
                    </div>
                </div>
                <input type="hidden" id="ExternalUnitId" name="ExternalUnitId" value="@Model.ExternalUnitId" />
            </form>
        </div>
    </div>
</div>

<!-- ROW 1: KPIs -->
<div class="row mb-4 g-3">
    <div class="col-md-3 col-6">
        <div class="card kpi-card h-100">
            <div class="card-body text-center py-4">
                <div class="kpi-ico" style="background:var(--info-light);color:var(--info);"><i class="bi bi-folder"></i></div>
                <div class="kpi-value" style="color:var(--primary);">@Model.ProjectCompletionRate%</div>
                <div class="kpi-label">إكمال الأهداف التشغيلية</div>
                <div class="progress mt-2" style="height:5px;">
                    <div class="progress-bar" style="width:@(Model.ProjectCompletionRate)%;background:var(--primary);"></div>
                </div>
                <small class="text-muted d-block mt-1">@Model.CompletedProjects من @Model.TotalProjects</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card kpi-card h-100">
            <div class="card-body text-center py-4">
                <div class="kpi-ico" style="background:var(--success-light);color:var(--success);"><i class="bi bi-list-check"></i></div>
                <div class="kpi-value" style="color:var(--success);">@Model.StepCompletionRate%</div>
                <div class="kpi-label">إكمال الخطوات التنفيذية</div>
                <div class="progress mt-2" style="height:5px;">
                    <div class="progress-bar bg-success" style="width:@(Model.StepCompletionRate)%;"></div>
                </div>
                <small class="text-muted d-block mt-1">@Model.CompletedSteps من @Model.TotalSteps</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card kpi-card h-100">
            <div class="card-body text-center py-4">
                <div class="kpi-ico" style="background:var(--warning-light);color:var(--warning);"><i class="bi bi-speedometer"></i></div>
                <div class="kpi-value" style="color:@effColor;">@Model.TimeEfficiencyIndex%</div>
                <div class="kpi-label">الكفاءة الزمنية</div>
                <div class="progress mt-2" style="height:5px;">
                    <div class="progress-bar" style="width:@(Math.Min(100, Model.TimeEfficiencyIndex))%;background:@effColor;"></div>
                </div>
                <small class="text-muted d-block mt-1">@effLabel — الإنجاز مقابل الوقت</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card kpi-card h-100">
            @if (Model.DelayedProjects > 0 || Model.AtRiskProjects > 0)
            {
                <div class="card-body text-center py-4" style="border-right:3px solid var(--danger);">
                    <div class="kpi-ico" style="background:var(--danger-light);color:var(--danger);"><i class="bi bi-exclamation-triangle"></i></div>
                    <div class="kpi-value" style="color:var(--danger);">@Model.DelayedProjects</div>
                    <div class="kpi-label">أهداف تشغيلية متأخرة</div>
                   @*  <div class="d-flex justify-content-center gap-1 mt-2 flex-wrap">
                        <span class="badge badge-cancelled">@Model.DelayedSteps خطوة متأخرة</span>
                        @if (Model.AtRiskProjects > 0)
                        {
                            <span class="badge badge-delayed">@Model.AtRiskProjects في خطر</span>
                        }
                    </div> *@
                </div>
            }
            else
            {
                <div class="card-body text-center py-4" style="border-right:3px solid var(--success);">
                    <div class="kpi-ico" style="background:var(--success-light);color:var(--success);"><i class="bi bi-check-circle"></i></div>
                    <div class="kpi-value" style="color:var(--success);">0</div>
                    <div class="kpi-label">أهداف تشغيلية متأخرة</div>
                    <div class="mt-2">
                        <span class="badge badge-completed"><i class="bi bi-check-circle me-1"></i>جميع الأهداف التشغيلية في الموعد</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ROW 2: CHARTS -->
<div class="row mb-4 g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-pie-chart me-2"></i>توزيع حالات الأهداف التشغيلية
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="projectStatusChart" style="max-height:230px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-bar-chart-horizontal me-2"></i>أداء الوحدات التنظيمية
            </div>
            <div class="card-body">
                <canvas id="unitPerformanceChart" style="max-height:230px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4 g-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-calendar-range me-2"></i>الجدول الزمني للأهداف التشغيلية
                <small class="text-muted float-end" style="font-size:.72rem;">المخطط مع نسبة الإنجاز</small>
            </div>
            <div class="card-body" style="padding:0.5rem;">
                <div id="ganttChart" style="width:100%;min-height:300px;"></div>
                <div class="d-flex justify-content-center gap-3 mt-1" style="font-size:.75rem;">
                    <span><span style="display:inline-block;width:20px;height:10px;border-radius:3px;background:#d1fae5;border:1px solid #0e7d5a;margin-left:4px;"></span> المدة المخططة</span>
                    <span><span style="display:inline-block;width:20px;height:10px;border-radius:3px;background:#0e7d5a;margin-left:4px;"></span> الإنجاز الفعلي</span>
                    <span><span style="display:inline-block;width:2px;height:12px;border-right:2px dashed #C9A84C;margin-left:4px;"></span> اليوم</span>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- ROW 3: SUNBURST — خريطة الخطة الهرمية -->
<div class="row mb-4 g-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-diagram-3 me-2"></i>خريطة الخطة التشغيلية</span>
                <div>
                    <small class="text-muted me-3" style="font-size:.72rem;">الوحدات التنظيمية ← الأهداف التشغيلية</small>
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn btn-outline-secondary btn-sm active" onclick="setSunburstColor('status')">حسب الحالة</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="setSunburstColor('progress')">حسب الإنجاز</button>
                    </div>
                </div>
            </div>
            <div class="card-body text-center" style="padding:0.5rem;position:relative;">
                <button id="sunburstBackBtn" class="btn btn-sm btn-outline-secondary" onclick="resetSunburst()"
                        style="position:absolute;top:10px;right:10px;z-index:10;display:none;">
                    <i class="bi bi-arrow-clockwise me-1"></i>عودة
                </button>
                <div id="sunburstChart" style="width:100%;height:420px;"></div>
                <div class="d-flex justify-content-center gap-3 mt-1" style="font-size:.75rem;">
                    <span class="text-muted fw-bold">الحلقة الداخلية: الوحدات التنظيمية</span>
                    <span class="opacity-25">|</span>
                    <span class="text-muted fw-bold">الحلقة الخارجية: المشاريع</span>
                    <span class="opacity-25">|</span>
                    <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#0e7d5a;margin-left:4px;"></span> مكتمل</span>
                    <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#2D4A22;margin-left:4px;"></span> جاري</span>
                    <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#b91c1c;margin-left:4px;"></span> متأخر</span>
                    <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#94a3b8;margin-left:4px;"></span> لم يبدأ</span>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- ROW 6: RISK + ALERTS -->
<div class="row mb-4 g-3">
    @if (Model.AtRiskProjectsList.Any())
    {
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header" style="background:linear-gradient(90deg, #fef3c7, #fde68a);color:#92400e;border-bottom-color:#fcd34d;">
                    <i class="bi bi-shield-exclamation me-2"></i>مشاريع في خطر
                    <span class="badge" style="background:#92400e;color:white;" class="float-end">@Model.AtRiskProjects</span>
                    <small class="float-end me-2" style="font-size:.7rem;opacity:.7;">إنجاز أقل من المتوقع</small>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle" style="font-size:.85rem;">
                            <thead>
                                <tr>
                                    <th>المشروع</th>
                                    <th class="text-center">الإنجاز</th>
                                    <th class="text-center">المتوقع</th>
                                    <th class="text-center">الفجوة</th>
                                    <th class="text-center">الخطورة</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var risk in Model.AtRiskProjectsList.Take(5))
                                {
                                    <tr>
                                        <td>
                                            <a href="/Projects/Details/@risk.Id" class="fw-semibold text-dark text-decoration-none">@risk.Name</a>
                                            <div class="text-muted" style="font-size:.72rem;">@risk.InitiativeName</div>
                                        </td>
                                        <td class="text-center fw-bold" style="color:var(--danger);">@risk.Progress%</td>
                                        <td class="text-center text-muted">@risk.ExpectedProgress%</td>
                                        <td class="text-center">
                                            <span class="fw-bold" style="color:var(--danger);">-@risk.Gap%</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @risk.RiskBadgeClass">@risk.RiskLevel</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    <div class="@(Model.AtRiskProjectsList.Any() ? "col-md-5" : "col-12")">
        <div class="card h-100">
            <div class="card-header" style="background:var(--danger-light);color:var(--danger);border-bottom-color:#fca5a5;">
                <i class="bi bi-exclamation-triangle me-2"></i>يتطلب انتباهاً فورياً
                @if (Model.OverdueProjects.Any() || Model.OverdueSteps.Any())
                {
                    <span class="badge badge-cancelled float-end">@(Model.OverdueProjects.Count + Model.OverdueSteps.Count)</span>
                }
            </div>
            <div class="card-body p-2" style="max-height:300px;overflow-y:auto;">
                @await Html.PartialAsync("_OverdueAlerts", Model)
            </div>
        </div>
    </div>
</div>



<!-- ROW 5: BOTTOM INITIATIVES + TOP INITIATIVES -->
<div class="row mb-4 g-3">
    @if (Model.BottomInitiatives.Any())
    {
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header" style="background:var(--danger-light);color:var(--danger);border-bottom-color:#fca5a5;">
                    <i class="bi bi-arrow-down-circle me-2"></i>مبادرات تحتاج تدخل
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>المبادرة</th>
                                    <th class="text-center" style="width:70px;">المشاريع</th>
                                    <th style="width:120px;">الإنجاز</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.BottomInitiatives)
                                {
                                    <tr>
                                        <td>
                                            <a href="/Initiatives/Details/@item.Id" class="fw-semibold text-dark text-decoration-none" style="font-size:.85rem;">@item.Name</a>
                                            <div class="text-muted" style="font-size:.72rem;">@item.UnitName</div>
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="badge badge-completed">@item.CompletedProjectsCount</span>/@item.ProjectsCount
                                        </td>
                                        <td class="align-middle">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-fill" style="height:5px;">
                                                    <div class="progress-bar bg-danger" style="width:@(Math.Max(item.Progress, 3))%;"></div>
                                                </div>
                                                <small class="fw-bold text-nowrap text-danger">@item.Progress%</small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (Model.TopInitiatives.Any())
    {
        <div class="@(Model.BottomInitiatives.Any() ? "col-md-6" : "col-12")">
            <div class="card h-100">
                <div class="card-header" style="background:var(--success-light);color:var(--success);border-bottom-color:#a7f3d0;">
                    <i class="bi bi-trophy me-2"></i>أفضل المبادرات أداءً
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>المبادرة</th>
                                    <th class="text-center" style="width:70px;">المشاريع</th>
                                    <th style="width:120px;">الإنجاز</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.TopInitiatives)
                                {
                                    <tr>
                                        <td>
                                            <a href="/Initiatives/Details/@item.Id" class="fw-semibold text-dark text-decoration-none" style="font-size:.85rem;">@item.Name</a>
                                            <div class="text-muted" style="font-size:.72rem;">@item.UnitName</div>
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="badge badge-completed">@item.CompletedProjectsCount</span>/@item.ProjectsCount
                                        </td>
                                        <td class="align-middle">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-fill" style="height:5px;">
                                                    <div class="progress-bar bg-success" style="width:@(item.Progress)%;"></div>
                                                </div>
                                                <small class="fw-bold text-nowrap">@item.Progress%</small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>



<!-- ROW 6: UNIT TABLE -->
@if (Model.UnitSummaries.Any())
{
    <div class="row mb-4 g-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-building me-2"></i>ملخص أداء الوحدات
                    <small class="text-muted float-end" style="font-size:.72rem;"><i class="bi bi-hand-index me-1"></i>اضغط للتفاصيل</small>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>الوحدة</th>
                                    <th class="text-center">مبادرات</th>
                                    <th class="text-center">مشاريع</th>
                                    <th class="text-center"><span class="text-success">مكتمل</span> / <span class="text-danger">متأخر</span></th>
                                    <th style="width:180px;">الإنجاز</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var unit in Model.UnitSummaries)
                                {
                                    var uid = (unit.ExternalUnitId ?? unit.UnitId)?.ToString() ?? "";
                                    var unitNameJs = (unit.UnitName ?? "").Replace("'", "\\'");
                                    string pc;
                                    if (unit.AverageProgress >= 80) { pc = "var(--success)"; }
                                    else if (unit.AverageProgress >= 50) { pc = "var(--primary-light)"; }
                                    else if (unit.AverageProgress >= 30) { pc = "var(--warning)"; }
                                    else { pc = "var(--danger)"; }
                                    <tr style="cursor:pointer;" onclick="showUnitDrillDown('@unitNameJs', '@uid')">
                                        <td><strong style="font-size:.875rem;">@unit.UnitName</strong></td>
                                        <td class="text-center">@unit.InitiativeCount</td>
                                        <td class="text-center">@unit.ProjectCount</td>
                                        <td class="text-center">
                                            <span class="badge badge-completed">@unit.CompletedCount</span>
                                            @if (unit.DelayedCount > 0)
                                            {
                                                <span class="badge badge-cancelled">@unit.DelayedCount</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-fill" style="height:8px;">
                                                    <div class="progress-bar" style="width:@(Math.Max(unit.AverageProgress, 5))%;background:@pc;"></div>
                                                </div>
                                                <small class="fw-bold text-nowrap" style="min-width:36px;">@unit.AverageProgress%</small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Drill-Down Data (hidden) -->
<div id="delayedDrillData" style="display:none;">
    @await Html.PartialAsync("_OverdueAlerts", Model)
</div>

<!-- DRILL-DOWN MODAL -->
<div class="modal fade" id="drillDownModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-list-ul me-2"></i><span id="drillDownLabel">التفاصيل</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="drillDownContent"></div>
            <div class="modal-footer">
                <a href="#" id="drillDownLink" class="btn btn-primary btn-sm">
                    <i class="bi bi-box-arrow-up-right me-1"></i>عرض الكل
                </a>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script src="~/lib/echarts/echarts.min.js"></script>
    <script>
        window.ReportsConfig = {
            selectedExternalUnitId: '@(Model.ExternalUnitId?.ToString() ?? "")'
        };
    </script>
    <script src="~/js/reports-dashboard.js"></script>
}

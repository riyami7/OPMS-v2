@model OperationalPlanMS.Models.ViewModels.RoleFormViewModel
@{
    ViewData["Title"] = "تعديل دور";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">تعديل الدور</h4>
        <p class="text-muted mb-0">@Model.NameAr</p>
    </div>
    <a href="/Roles" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-controller="Roles" asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label asp-for="Code" class="form-label"></label>
                        <input asp-for="Code" class="form-control" readonly />
                        <small class="text-muted">لا يمكن تغيير كود الدور</small>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NameAr" class="form-label"></label>
                        <input asp-for="NameAr" class="form-control" />
                        <span asp-validation-for="NameAr" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NameEn" class="form-label"></label>
                        <input asp-for="NameEn" class="form-control" dir="ltr" />
                        <span asp-validation-for="NameEn" class="text-danger small"></span>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>حفظ التغييرات
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

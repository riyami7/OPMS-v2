@model OperationalPlanMS.Models.ViewModels.RoleListViewModel
@{
    ViewData["Title"] = "إدارة الأدوار";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">إدارة الأدوار</h4>
        <p class="text-muted mb-0">عرض وتعديل أدوار المستخدمين</p>
    </div>
    <a href="/Admin" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الاسم بالعربية</th>
                        <th>الاسم بالإنجليزية</th>
                        <th>الوصف</th>
                        <th style="width: 100px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Roles)
                    {
                        var roleClass = item.Id switch
                        {
                            1 => "bg-danger",
                            2 => "bg-primary",
                            3 => "bg-success",
                            4 => "bg-secondary",
                            _ => "bg-secondary"
                        };
                        var roleDesc = item.Id switch
                        {
                            1 => "صلاحيات كاملة على النظام",
                            2 => "عرض جميع البيانات (للقراءة فقط)",
                            3 => "إدارة المبادرات المُشرف عليها",
                            4 => "إدارة المشاريع المُعينة فقط",
                            _ => ""
                        };
                        <tr>
                            <td>
                                <span class="badge @roleClass">@item.Code</span>
                            </td>
                            <td><strong>@item.NameAr</strong></td>
                            <td dir="ltr" class="text-end">@item.NameEn</td>
                            <td><small class="text-muted">@roleDesc</small></td>
                            <td>
                                <a href="/Roles/Edit/@item.Id" class="btn btn-sm btn-outline-warning" title="تعديل">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


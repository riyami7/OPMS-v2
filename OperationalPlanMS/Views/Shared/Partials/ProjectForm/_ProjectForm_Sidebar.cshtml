@model OperationalPlanMS.Models.ViewModels.ProjectFormViewModel
@{
    var isEdit = Model.Id != 0;
}

<!-- التواريخ -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-calendar me-2"></i>التواريخ</div>
    <div class="card-body">
        <div class="mb-3">
            <label asp-for="PlannedStartDate" class="form-label">تاريخ البداية المتوقع <span class="text-danger">*</span></label>
            <input asp-for="PlannedStartDate" type="date" class="form-control" id="plannedStartDate" onchange="checkMultiYear()" required />
            <span asp-validation-for="PlannedStartDate" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="PlannedEndDate" class="form-label">تاريخ النهاية المتوقع <span class="text-danger">*</span></label>
            <input asp-for="PlannedEndDate" type="date" class="form-control" id="plannedEndDate" onchange="checkMultiYear()" required />
            <span asp-validation-for="PlannedEndDate" class="text-danger"></span>
        </div>
        <hr>
        <div class="mb-3">
            <label asp-for="ActualStartDate" class="form-label">تاريخ البداية الفعلي</label>
            <input asp-for="ActualStartDate" type="date" class="form-control" />
        </div>
        <div class="mb-0">
            <label asp-for="ActualEndDate" class="form-label">تاريخ النهاية الفعلي</label>
            <input asp-for="ActualEndDate" type="date" class="form-control" />
        </div>
    </div>
</div>

<!-- نسب السنوات -->
<div class="card mb-4" id="multiYearCard" style="display: none;">
    <div class="card-header">
        <i class="bi bi-calendar-range me-2"></i>نسب السنوات
        <span class="badge bg-white text-info ms-2" id="yearCount">0</span>
    </div>
    <div class="card-body">
        <div class="alert alert-warning py-2 mb-3">
            <small><i class="bi bi-exclamation-triangle me-1"></i>المجموع يجب أن يساوي <strong>100%</strong></small>
        </div>
        <div id="yearTargetsContainer"></div>
        <div class="d-flex justify-content-between mt-2">
            <span class="text-muted">المجموع:</span>
            <span id="totalYearPercentage" class="badge bg-secondary">0%</span>
        </div>
    </div>
</div>

<!-- الميزانية -->
<div class="card mb-4">
    <div class="card-header">الميزانية</div>
    <div class="card-body">
        <div class="mb-3">
            <label asp-for="Budget" class="form-label">التكلفة الرأسمالية</label>
            <div class="input-group">
                <input asp-for="Budget" type="number" step="0.01" class="form-control" />
                <span class="input-group-text">ر.ع</span>
            </div>
        </div>
        <div class="mb-0">
            <label asp-for="ActualCost" class="form-label">التكلفة التشغيلية</label>
            <div class="input-group">
                <input asp-for="ActualCost" type="number" step="0.01" class="form-control" />
                <span class="input-group-text">ر.ع</span>
            </div>
        </div>
    </div>
</div>

<!-- معلومات إضافية -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-file-text me-2"></i>معلومات إضافية</div>
    <div class="card-body">
        <div class="mb-3">
            <label asp-for="ExpectedOutcomes" class="form-label">المخرجات المتوقعة</label>
            <textarea asp-for="ExpectedOutcomes" class="form-control" rows="2"></textarea>
        </div>
        <div class="mb-0">
            <label asp-for="RiskNotes" class="form-label">ملاحظات المخاطر</label>
            <textarea asp-for="RiskNotes" class="form-control" rows="2"></textarea>
        </div>
    </div>
</div>

<div class="d-grid gap-2">
    <button type="submit" class="btn btn-primary btn-lg">
        <i class="bi bi-check-lg me-2"></i>@(isEdit ? "حفظ التغييرات" : "إضافة الهدف التشغيلي")
    </button>
    @if (isEdit)
    {
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">إلغاء</a>
    }
    else
    {
        <a asp-action="Details" asp-controller="Initiatives" asp-route-id="@Model.InitiativeId" class="btn btn-outline-secondary">إلغاء</a>
    }
</div>

@*
    فقاعة المحادثة العائمة — المساعد الذكي
    شرطين للعرض:
      1. الإعداد العام IsChatbotEnabled = true
      2. دور المستخدم: Admin / Executive / Supervisor
*@
@using OperationalPlanMS.Models
@using OperationalPlanMS.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@{
    // ===== شرط 1: الإعداد العام =====
    var sysSettings = await Db.SystemSettings.AsNoTracking().FirstOrDefaultAsync();
    var chatEnabled = sysSettings?.IsChatbotEnabled ?? true;

    // ===== شرط 2: صلاحية المستخدم =====
    var chatRoleStr = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    Enum.TryParse<UserRole>(chatRoleStr, out UserRole chatRole);

    var chatUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
    var chatUserName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";

    var canUseChat = chatEnabled && (
        chatRole == UserRole.Admin
        || chatRole == UserRole.Executive
        || chatRole == UserRole.Supervisor
    );
}

@if (canUseChat)
{
    <!-- الزر العائم -->
    <button id="chatFab" class="aichat-fab" title="المساعد الذكي">
        <svg class="aichat-fab__ico aichat-fab__ico--msg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" /><circle cx="8" cy="12" r=".8" fill="currentColor" stroke="none" /><circle cx="12" cy="12" r=".8" fill="currentColor" stroke="none" /><circle cx="16" cy="12" r=".8" fill="currentColor" stroke="none" /></svg>
        <svg class="aichat-fab__ico aichat-fab__ico--x" style="display:none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
        <span class="aichat-fab__ring"></span>
    </button>

    <!-- نافذة المحادثة -->
    <div id="chatWin" class="aichat" style="display:none">
        <div class="aichat__hd">
            <div class="aichat__hd-id">
                <div class="aichat__hd-ava">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a4 4 0 0 1 4 4v1a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z" /><rect x="5" y="12" width="14" height="8" rx="3" /><circle cx="9.5" cy="16" r="1" fill="currentColor" stroke="none" /><circle cx="14.5" cy="16" r="1" fill="currentColor" stroke="none" /></svg>
                    <span class="aichat__hd-dot"></span>
                </div>
                <div class="aichat__hd-txt">
                    <strong>المساعد الذكي</strong>
                    <small id="chatSt"><span class="aichat__hd-dotg"></span>متصل</small>
                </div>
            </div>
            <div class="aichat__hd-acts">
                <button id="chatClr" class="aichat__hd-btn" title="مسح المحادثة"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1.5 14a2 2 0 0 1-2 1.8H8.5a2 2 0 0 1-2-1.8L5 6" /></svg></button>
                <button id="chatMin" class="aichat__hd-btn" title="إغلاق"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><polyline points="6 9 12 15 18 9" /></svg></button>
            </div>
        </div>

        <div class="aichat__bd" id="chatBd">
            <div class="aichat__hi" id="chatHi">
                <div class="aichat__hi-ava">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2a4 4 0 0 1 4 4v1a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z" /><rect x="5" y="12" width="14" height="8" rx="3" /><circle cx="9.5" cy="16" r="1" fill="currentColor" stroke="none" /><circle cx="14.5" cy="16" r="1" fill="currentColor" stroke="none" /></svg>
                </div>
                <div class="aichat__hi-t">مرحباً @chatUserName، كيف أقدر أساعدك؟</div>
                <div class="aichat__hi-s">اسألني عن المبادرات، المشاريع، أو أي شيء في النظام</div>
                <div class="aichat__chips">
                    <button class="aichat__chip" data-m="ما هي المبادرات الجارية؟">📊 المبادرات الجارية</button>
                    <button class="aichat__chip" data-m="أعطني ملخص تقدم المشاريع">📋 تقدم المشاريع</button>
                    <button class="aichat__chip" data-m="ما هي الخطوات المتأخرة؟">⏰ الخطوات المتأخرة</button>
                </div>
            </div>
        </div>

        <div class="aichat__ft">
            <div class="aichat__inp-wrap">
                <textarea id="chatInp" class="aichat__inp" placeholder="اكتب رسالتك..." rows="1" maxlength="2000"></textarea>
                <button id="chatSnd" class="aichat__snd" disabled title="إرسال">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg>
                </button>
            </div>
            <div class="aichat__hint">Enter إرسال · Shift+Enter سطر جديد</div>
        </div>
    </div>

    <script>
        window.CHAT_CONFIG = {
            apiBaseUrl: 'http://localhost:8000',
            apiToken: '',
            streaming: true,
            useRag: false,
            opmsApiBaseUrl: '',
            opmsApiKey: '@(ViewBag.OpmsApiKey ?? "opms-api-key-change-me-in-production")',
            userId: @chatUserId,
            userRole: '@chatRole',
            userName: '@chatUserName'
        };
    </script>
    <script src="~/js/chat-bubble.js"></script>
}

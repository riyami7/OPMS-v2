@using OperationalPlanMS.Models
@using Microsoft.EntityFrameworkCore
@inject OperationalPlanMS.Data.AppDbContext OrgDbContext
@{
    var userRoleStr = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    Enum.TryParse<UserRole>(userRoleStr, out UserRole userRole);

    var isAdmin = userRole == UserRole.Admin || userRole == UserRole.SuperAdmin;
    var isSuperAdmin = userRole == UserRole.SuperAdmin;
    var isExecutive = userRole == UserRole.Executive;
    var isSupervisor = userRole == UserRole.Supervisor;
    var isUser = userRole == UserRole.User;
    var isStepUser = userRole == UserRole.StepUser;

    // صلاحيات العرض — الكل يشوف المبادرات والمشاريع والخطوات
    var canViewDashboard = isAdmin || isExecutive;
    var canViewInitiatives = true; // الكل يشوف (الفلترة في الـ Service)
    var canViewProjects = true;    // الكل يشوف
    var canViewSteps = true;       // الكل يشوف
    var canViewReports = isAdmin || isExecutive || isSupervisor;
    var canViewAdmin = isAdmin;

    // ========== جلب الوحدات التنظيمية مرة واحدة لكل الصفحات ==========
    // يُحمّل مع الصفحة بدل ما يحتاج AJAX - يسرّع OrgTreePicker بشكل كبير
    var orgUnitsData = await OrgDbContext.ExternalOrganizationalUnits
        .AsNoTracking()
        .Where(u => u.IsActive)
        .OrderBy(u => u.ArabicName)
        .Select(u => new
        {
            id = u.Id,
            parentId = u.ParentId,
            name = u.ArabicName ?? u.ArabicUnitName ?? "",
            code = u.Code
        })
        .ToListAsync();

    // الصورة الشخصية من Claims
    var profileImage = User.FindFirst("ProfileImage")?.Value;

    var strategicActions = new[] { "StrategicOverview", "VisionMission", "StrategicObjectives", "CoreValues" };
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isStrategicActive = strategicActions.Contains(currentAction);
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام إدارة الخطط التشغيلية</title>

    <!-- AlQabas Font (Local) -->
    <style>
        @@font-face {
            font-family: 'AlQabas';
            src: url('/lib/fonts/AlQabas/AlQabas-Light.ttf') format('truetype');
            font-weight: 300;
            font-display: swap;
        }

        @@font-face {
            font-family: 'AlQabas';
            src: url('/lib/fonts/AlQabas/AlQabas-Regular.ttf') format('truetype');
            font-weight: 400;
            font-display: swap;
        }

        @@font-face {
            font-family: 'AlQabas';
            src: url('/lib/fonts/AlQabas/AlQabas-Bold.ttf') format('truetype');
            font-weight: 700;
            font-display: swap;
        }

        body {
            font-family: 'AlQabas', 'Segoe UI', sans-serif;
        }
    </style>

    <!-- Bootstrap 5 RTL CSS (Local) -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" rel="stylesheet">

    <!-- Bootstrap Icons (Local) -->
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/org-tree-picker.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat-bubble.css" />
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <i class="bi bi-clipboard-data"></i>
                <div class="sidebar-brand">
                    <span class="brand-text">نظام الخطط التشغيلية</span>
                    <small>OPS</small>
                </div>
            </div>

            <nav class="sidebar-nav">
                <ul class="nav flex-column">

                    <!-- الخطة الاستراتيجية - ليس للـ StepUser -->
                    @if (!isStepUser)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(isStrategicActive ? "active" : "")" href="/Home/StrategicOverview">
                                <i class="bi bi-bullseye"></i>
                                <span>الخطة الاستراتيجية</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" href="/">
                                <i class="bi bi-house"></i>
                                <span>الرئيسية</span>
                            </a>
                        </li>
                    }

                    <li class="nav-section">الإدارة</li>

                    <!-- المبادرات -->
                    @if (canViewInitiatives)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Initiatives" ? "active" : "")" href="/Initiatives">
                                <i class="bi bi-lightning-charge"></i>
                                <span>@(isAdmin || isExecutive ? "الوحدات التنظيمية" : "الوحدات التنظيمية")</span>
                            </a>
                        </li>
                    }

                    <!-- المشاريع -->
                    @if (canViewProjects)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")" href="/Projects">
                                <i class="bi bi-folder"></i>
                                <span>@(isAdmin || isExecutive ? "الأهداف التشغيلية" : "أهدافي التشغيلية")</span>
                            </a>
                        </li>
                    }

                    <!-- الخطوات -->
                    @if (canViewSteps)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Steps" && ViewContext.RouteData.Values["action"]?.ToString() != "PendingApprovals" ? "active" : "")" href="/Steps">
                                <i class="bi bi-list-check"></i>
                                        <span>@(isAdmin || isExecutive ? "الخطوات التنفيذية" : "الخطوات التنفيذية")</span>
                            </a>
                        </li>
                    }

                    <!-- الخطوات المعلقة - لمدير الوحدة و SuperAdmin فقط -->
                    @if (isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "PendingApprovals" ? "active" : "")" href="/Steps/PendingApprovals">
                                <i class="bi bi-clipboard-check"></i>
                                <span>سجل التدقيق والمتابعة</span>
                                <span id="pendingBadge" class="badge bg-danger ms-auto" style="font-size:.6rem;display:none;">0</span>
                            </a>
                        </li>
                    }

                    <!-- التقارير - Admin, Executive, Supervisor -->
                    @if (canViewReports)
                    {
                        <li class="nav-section">التقارير</li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")" href="/Reports">
                                <i class="bi bi-file-earmark-bar-graph"></i>
                                <span>التقارير</span>
                            </a>
                        </li>
                    }

                    <!-- إعدادات النظام - Admin فقط -->
                    @if (canViewAdmin)
                    {
                        <li class="nav-section">النظام</li>

                        @if (isSuperAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audit" ? "active" : "")" href="/Audit">
                                    <i class="bi bi-shield-check"></i>
                                    <span>سجل التدقيق</span>
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")" href="/Admin">
                                <i class="bi bi-gear"></i>
                                <span>إعدادات النظام</span>
                            </a>
                        </li>
                    }
                </ul>
            </nav>

            <div class="sidebar-footer">
                <small>&copy; 2026 OPS</small>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <button class="btn btn-link sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>

                <div class="header-title">
                    <h5 class="mb-0">@ViewData["Title"]</h5>
                </div>

                <div class="header-actions">
                    <!-- Tenant Switcher — SuperAdmin فقط -->
                    @if (isSuperAdmin)
                    {
                        <div class="dropdown me-3" id="tenantSwitcher">
                            <button class="btn btn-sm dropdown-toggle" data-bs-toggle="dropdown"
                                    style="background:var(--accent);color:white;border:none;font-size:.82rem;padding:4px 12px;border-radius:6px;">
                                <i class="bi bi-building-gear me-1"></i>
                                <span id="tenantSwitcherLabel">جميع الوحدات</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-start shadow" style="min-width:250px;" id="tenantDropdown">
                                <li>
                                    <form asp-controller="Admin" asp-action="SwitchTenant" method="post" class="d-inline w-100">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="tenantId" value="" />
                                        <button type="submit" class="dropdown-item py-2" id="tenantAll">
                                            <i class="bi bi-globe me-2 text-primary"></i>
                                            <strong>جميع الوحدات</strong>
                                        </button>
                                    </form>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li class="text-center py-2 text-muted" id="tenantLoading">
                                    <small>جاري التحميل...</small>
                                </li>
                            </ul>
                        </div>
                    }

                    <!-- Notifications Bell -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown me-2">
                            <button class="btn btn-link position-relative" data-bs-toggle="dropdown" onclick="loadNotifications()" style="color:var(--text-primary);font-size:1.2rem;">
                                <i class="bi bi-bell"></i>
                                <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:.6rem;display:none;">0</span>
                            </button>
                            <div class="dropdown-menu dropdown-menu-start shadow" style="width:360px;max-height:450px;overflow-y:auto;" id="notifDropdown">
                                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                    <strong style="font-size:.9rem;">الإشعارات</strong>
                                    <button class="btn btn-sm btn-link text-primary p-0" onclick="markAllNotifRead()" style="font-size:.78rem;">تحديد الكل كمقروء</button>
                                </div>
                                <div id="notifList">
                                    <div class="text-center py-4 text-muted"><small>جاري التحميل...</small></div>
                                </div>
                                <div class="border-top text-center py-2">
                                    <a href="/Notification" class="text-decoration-none" style="font-size:.82rem;">عرض جميع الإشعارات</a>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- User Menu -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown user-menu">
                            <button class="btn btn-link dropdown-toggle" data-bs-toggle="dropdown">
                                <div class="user-avatar">
                                    @if (!string.IsNullOrEmpty(profileImage))
                                    {
                                        <img src="@profileImage" alt="Profile" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <i class="bi bi-person"></i>
                                    }
                                </div>
                                <div class="user-info d-none d-md-block">
                                    <span class="user-name">@User.Identity.Name</span>
                                    <small class="user-role">@User.FindFirst("RoleNameAr")?.Value</small>
                                </div>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-start">
                                <li>
                                    <a class="dropdown-item" href="/Profile">
                                        <i class="bi bi-person me-2"></i>الملف الشخصي
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Profile/ChangePassword">
                                        <i class="bi bi-key me-2"></i>تغيير كلمة المرور
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-left me-2"></i>تسجيل الخروج
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </header>

            <!-- Page Content -->
            <main class="page-content">
                <!-- Alert Messages -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="main-footer">
                <span>&copy; 2026 نظام إدارة الخطط التشغيلية - OPS</span>
            </footer>
        </div>
    </div>

    <!-- jQuery (Local) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Bootstrap 5 JS (Local) -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Sidebar Toggle
        document.getElementById('sidebarToggle').addEventListener('click', function() {
            document.querySelector('.wrapper').classList.toggle('sidebar-collapsed');
        });
    </script>

    <!-- Safe DOM Helpers — XSS Prevention -->
    <script src="~/js/safe-dom.js"></script>

    <!-- ========== بيانات الوحدات التنظيمية (محقونة من السيرفر) ========== -->
    <!-- تُستخدم من OrgTreePicker مباشرة بدون AJAX → تحميل فوري -->
    <script type="application/json" id="orgUnitsData">@Html.Raw(Json.Serialize(orgUnitsData))</script>

    <script src="~/js/org-tree-picker.js"></script>

    <!-- Notifications -->
    <script>
        function loadNotifications() {
            fetch('/Notification/GetDropdown')
                .then(r => r.json())
                .then(data => {
                    var badge = document.getElementById('notifBadge');
                    if (data.unreadCount > 0) { badge.textContent = data.unreadCount; badge.style.display = ''; }
                    else { badge.style.display = 'none'; }

                    var list = document.getElementById('notifList');
                    if (!data.notifications || data.notifications.length === 0) {
                        list.innerHTML = '<div class="text-center py-4 text-muted"><i class="bi bi-bell-slash" style="font-size:1.5rem;"></i><br><small>لا توجد إشعارات</small></div>';
                        return;
                    }
                    list.innerHTML = data.notifications.map(function(n) {
                        return '<a href="' + (n.url || '/Notification') + '" class="dropdown-item py-2 ' + (!n.isRead ? 'bg-light' : '') + '" onclick="markNotifRead(' + n.id + ')" style="white-space:normal;">' +
                            '<div class="d-flex gap-2 align-items-start">' +
                            '<i class="bi ' + n.icon + ' ' + n.typeBadgeClass + '" style="font-size:1.1rem;margin-top:2px;"></i>' +
                            '<div style="flex:1;min-width:0;">' +
                            '<div style="font-size:.83rem;font-weight:' + (!n.isRead ? '700' : '400') + ';">' + n.title + '</div>' +
                            (n.message ? '<small class="text-muted d-block" style="font-size:.75rem;">' + n.message + '</small>' : '') +
                            '<small class="text-muted" style="font-size:.7rem;">' + n.timeAgo + '</small>' +
                            '</div></div></a>';
                    }).join('');
                });
        }
        function markNotifRead(id) { fetch('/Notification/MarkAsRead/' + id, { method: 'POST' }); }
        function markAllNotifRead() {
            fetch('/Notification/MarkAllAsRead', { method: 'POST' }).then(function() { loadNotifications(); });
        }
        // تحميل عدد الإشعارات عند فتح الصفحة
        if (document.getElementById('notifBadge')) {
            fetch('/Notification/GetDropdown').then(r => r.json()).then(data => {
                var badge = document.getElementById('notifBadge');
                if (data.unreadCount > 0) { badge.textContent = data.unreadCount; badge.style.display = ''; }
            });
        }

        // تحميل عدد الخطوات المعلقة عبر AJAX
        if (document.getElementById('pendingBadge')) {
            fetch('/Steps/GetPendingCount').then(r => r.json()).then(data => {
                var badge = document.getElementById('pendingBadge');
                if (data.count > 0) { badge.textContent = data.count; badge.style.display = ''; }
            });
        }

        // === Tenant Switcher ===
        (function() {
            var switcher = document.getElementById('tenantSwitcher');
            if (!switcher) return;

            var dropdown = document.getElementById('tenantDropdown');
            var label = document.getElementById('tenantSwitcherLabel');
            var loading = document.getElementById('tenantLoading');
            var loaded = false;

            switcher.addEventListener('show.bs.dropdown', function() {
                if (loaded) return;
                fetch('/Admin/GetTenants')
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (loading) loading.remove();
                        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

                        data.tenants.forEach(function(t) {
                            var li = document.createElement('li');
                            var isSelected = data.selectedId === t.id;
                            li.innerHTML =
                                '<form action="/Admin/SwitchTenant" method="post" class="d-inline w-100">' +
                                '<input type="hidden" name="__RequestVerificationToken" value="' + token + '">' +
                                '<input type="hidden" name="tenantId" value="' + t.id + '">' +
                                '<button type="submit" class="dropdown-item py-2' + (isSelected ? ' active' : '') + '">' +
                                '<i class="bi bi-building me-2"></i>' + t.name +
                                (isSelected ? ' <i class="bi bi-check-lg text-success float-start"></i>' : '') +
                                '</button></form>';
                            dropdown.appendChild(li);
                        });

                        // تحديث Label
                        if (data.selectedId) {
                            var selected = data.tenants.find(function(t) { return t.id === data.selectedId; });
                            if (selected) label.textContent = selected.name;
                        }

                        // تحديث زر "جميع الوحدات"
                        if (!data.selectedId) {
                            var allBtn = document.getElementById('tenantAll');
                            if (allBtn) allBtn.classList.add('active');
                        }

                        loaded = true;
                    });
            });

            // تحديث Label عند أول تحميل (بدون فتح dropdown)
            fetch('/Admin/GetTenants')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.selectedId) {
                        var selected = data.tenants.find(function(t) { return t.id === data.selectedId; });
                        if (selected) label.textContent = selected.name;
                    }
                });
        })();
    </script>

    <!-- المساعد الذكي (يتضمن التحقق من الصلاحيات والإعداد) -->
    @await Html.PartialAsync("_ChatWidget")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model OperationalPlanMS.Models.ViewModels.StepDetailsViewModel
@using OperationalPlanMS.Models
@using OperationalPlanMS.Models.Entities
@{
    ViewData["Title"] = Model.Step.NameAr;
    var canEdit = (bool)(ViewBag.CanEdit ?? false);
    var isAdmin = (ViewBag.UserRole as UserRole?) == UserRole.Admin;
    var userRole = ViewBag.UserRole as UserRole? ?? UserRole.User;
    var isStepApprover = (bool)(ViewBag.IsStepApprover ?? false);
    var isPendingApproval = Model.Step.ApprovalStatus == ApprovalStatus.Pending;
    var isApproved = Model.Step.ApprovalStatus == ApprovalStatus.Approved;
    var isRejected = Model.Step.ApprovalStatus == ApprovalStatus.Rejected;
    var canSeeHistory = isAdmin || userRole == UserRole.Supervisor || userRole == UserRole.Executive;
    var hasDocumentation = !string.IsNullOrEmpty(Model.Step.CompletionDetails)
                        || !string.IsNullOrEmpty(Model.Step.ApproverNotes)
                        || (Model.Step.Attachments != null && Model.Step.Attachments.Any());
    var assignedToName = !string.IsNullOrEmpty(Model.Step.AssignedToName)
        ? $"{Model.Step.AssignedToRank} {Model.Step.AssignedToName}".Trim()
        : Model.Step.AssignedTo?.FullNameAr ?? "غير معين";
    var assignedToEmpNumber = Model.Step.AssignedToEmpNumber;
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
            <span class="badge bg-secondary">مرحلة @Model.Step.StepNumber</span>
            <h5 class="mb-0">@Model.Step.NameAr</h5>
        </div>
        <small class="text-muted">
            <a href="/Projects/Details/@Model.Step.ProjectId" class="text-decoration-none">
                <i class="bi bi-folder me-1"></i>@Model.Step.Project?.NameAr
            </a>
            @if (Model.Step.Project?.Initiative != null)
            {
                <span class="mx-1 text-muted">›</span>
                <a href="/Initiatives/Details/@Model.Step.Project.Initiative.Id" class="text-decoration-none text-muted">
                    @Model.Step.Project.Initiative.NameAr
                </a>
            }
        </small>
    </div>
    <div class="d-flex gap-2">
        @if (canEdit)
        {
            <a href="/Steps/Edit/@Model.Step.Id" class="btn btn-sm btn-warning">
                <i class="bi bi-pencil me-1"></i>تعديل
            </a>
        }
        <a href="/Projects/Details/@Model.Step.ProjectId" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-right me-1"></i>رجوع للمشروع
        </a>
    </div>
</div>

<!-- ===== الإجراء المطلوب - بارز في الأعلى دائماً ===== -->
@if (isRejected && !string.IsNullOrEmpty(Model.Step.RejectionReason))
{
    <div class="alert alert-danger border-0 shadow-sm mb-3">
        <div class="d-flex align-items-start gap-3">
            <i class="bi bi-x-circle-fill fs-4 mt-1"></i>
            <div>
                <strong>تم رفض الخطوة التنفيذية</strong>
                <p class="mb-1 mt-1">@Model.Step.RejectionReason</p>
                @if (canEdit)
                {
                    <small class="text-muted">يمكنك إعادة إرسال الخطوة التنفيذية للتأكيد من تبويب <strong>الإجراءات</strong></small>
                }
            </div>
        </div>
    </div>
}

@if (isPendingApproval && !isStepApprover)
{
    <div class="alert alert-warning border-0 shadow-sm mb-3">
        <i class="bi bi-hourglass-split me-2"></i>
        <strong>بانتظار التأكيد</strong>
        <span class="text-muted ms-2">أُرسلت بتاريخ @Model.Step.SubmittedForApprovalAt?.ToString("yyyy/MM/dd")</span>
    </div>
}

@if (isStepApprover && isPendingApproval)
{
    <div class="alert alert-warning border-0 shadow-sm mb-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <i class="bi bi-clipboard-check me-2 fs-5"></i>
            <strong>هذه الخطوة التنفيذية تنتظر تأكيدك</strong>
            <span class="text-muted ms-2 d-none d-sm-inline">أُرسلت بتاريخ @Model.Step.SubmittedForApprovalAt?.ToString("yyyy/MM/dd")</span>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#approveStepModal">
                <i class="bi bi-check-lg me-1"></i>تأكيد
            </button>
            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectStepModal">
                <i class="bi bi-x-lg me-1"></i>رفض
            </button>
        </div>
    </div>
}

@if (Model.IsDelayed && !isPendingApproval && !isApproved)
{
    <div class="alert alert-danger border-0 shadow-sm mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>مرحلة متأخرة</strong> — تجاوزت تاريخ النهاية المتوقع ونسبة الإنجاز أقل من 100%
    </div>
}

<!-- ===== بطاقات الإحصاء ===== -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center h-100 @(isApproved ? "border-success" : Model.IsDelayed ? "border-danger" : isPendingApproval ? "border-warning" : "border-primary")">
            <div class="card-body py-3">
                <h3 class="mb-0 @(isApproved ? "text-success" : Model.IsDelayed ? "text-danger" : isPendingApproval ? "text-warning" : "text-primary")">
                    @((int)Model.Step.ProgressPercentage)%
                </h3>
                <p class="text-muted small mb-2">نسبة الإنجاز</p>
                <div class="progress" style="height: 4px;">
                    <div class="progress-bar @(isApproved ? "bg-success" : Model.IsDelayed ? "bg-danger" : isPendingApproval ? "bg-warning" : "bg-primary")"
                         style="width: @((int)Model.Step.ProgressPercentage)%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body py-3">
                <h3 class="mb-0 text-info">@((int)Model.Step.Weight)%</h3>
                <p class="text-muted small mb-1">الوزن في الهدف التشغيلي</p>
                <small class="@(isApproved ? "text-success" : "text-muted")">
                    @if (isApproved)
                    {
                        <span><i class="bi bi-check-circle me-1"></i>مضاف للهدف التشغيلي</span>
                    }
                    else if (isPendingApproval)
                    {

                        <span class="text-warning">⏳ بانتظار التأكيد</span>
                    }
                    else
                    {

                        <span>يُضاف بعد التأكيد</span>
                    }
                </small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body py-3">
                <i class="bi bi-person text-secondary fs-4"></i>
                <p class="mb-0 fw-bold small mt-1">@assignedToName</p>
                @if (Model.Step.AssignedTo?.EmployeePosition != null)
                {
                    <p class="text-muted small mb-0"><i class="bi bi-briefcase me-1"></i>@Model.Step.AssignedTo.EmployeePosition</p>
                }
                <p class="text-muted small mb-0">المسؤول</p>
                @if (!string.IsNullOrEmpty(assignedToEmpNumber))
                {
                    <small class="text-muted">@assignedToEmpNumber</small>
                }
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body py-3">
                <span class="badge @Model.StatusBadgeClass fs-6 mb-1">@Model.StatusText</span>
                <p class="text-muted small mb-0">الحالة</p>
                @if (Model.Step.ActualEndDate.HasValue)
                {
                    <small class="@(Model.IsDelayed ? "text-danger" : "text-muted")">
                        <i class="bi bi-calendar me-1"></i>@Model.Step.ActualEndDate.Value.ToString("yyyy-MM-dd")
                        @if (Model.IsDelayed)
                        {
                            <i class="bi bi-exclamation-triangle ms-1"></i>
                        }
                    </small>
                }
            </div>
        </div>
    </div>
</div>

<!-- ===== التبويبات ===== -->
<ul class="nav nav-tabs mb-4" id="stepTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tab-overview" data-bs-toggle="tab" data-bs-target="#pane-overview" type="button" role="tab">
            <i class="bi bi-info-circle me-1"></i>التفاصيل
        </button>
    </li>
    @if (hasDocumentation)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-docs" data-bs-toggle="tab" data-bs-target="#pane-docs" type="button" role="tab">
                <i class="bi bi-file-check me-1"></i>التوثيق
                @if (Model.Step.Attachments != null && Model.Step.Attachments.Any())
                {
                    <span class="badge bg-primary ms-1">@Model.Step.Attachments.Count</span>
                }
            </button>
        </li>
    }
    @if (canEdit && !isApproved && !isPendingApproval)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link @(isRejected ? "text-danger fw-bold" : "")"
                    id="tab-actions" data-bs-toggle="tab" data-bs-target="#pane-actions" type="button" role="tab">
                <i class="bi bi-send me-1"></i>الإجراءات
                @if (isRejected)
                {
                    <span class="badge bg-danger ms-1">!</span>
                }
            </button>
        </li>
    }
    @if (canSeeHistory)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-history" data-bs-toggle="tab" data-bs-target="#pane-history" type="button" role="tab">
                <i class="bi bi-journal-text me-1"></i>السجل
                @if (Model.Notes.Count > 0)
                {
                    <span class="badge bg-secondary ms-1">@Model.Notes.Count</span>
                }
            </button>
        </li>
    }
</ul>

<div class="tab-content" id="stepTabsContent">

    <!-- تبويب التفاصيل -->
    <div class="tab-pane fade show active" id="pane-overview" role="tabpanel">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-header"><i class="bi bi-card-text me-2"></i>الوصف</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <strong class="text-muted d-block small mb-1">الوصف بالعربية</strong>
                                <p class="mb-0">@(Model.Step.DescriptionAr ?? "لا يوجد وصف")</p>
                            </div>
                           @*  <div class="col-md-6 mb-3">
                                <strong class="text-muted d-block small mb-1">الوصف بالإنجليزية</strong>
                                <p dir="ltr" class="text-end mb-0">@(Model.Step.DescriptionEn ?? "No description")</p>
                            </div> *@
                            @if (!string.IsNullOrEmpty(Model.Step.Notes))
                            {
                                <div class="col-12">
                                    <strong class="text-muted d-block small mb-1">ملاحظات الخطوة التنفيذية</strong>
                                    <p class="mb-0">@Model.Step.Notes</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card mb-3">
                    <div class="card-header"><i class="bi bi-calendar me-2"></i>التواريخ</div>
                    <div class="card-body py-2">
                        <table class="table table-sm table-borderless mb-0">
                            <tr>
                                <td class="text-muted small">البداية المتوقعة</td>
                                <td class="text-end small">@Model.Step.PlannedStartDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                            <tr>
                                <td class="text-muted small">النهاية المتوقعة</td>
                                <td class="text-end small">@Model.Step.PlannedEndDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                            @if (Model.Step.ActualStartDate.HasValue)
                            {
                                <tr>
                                    <td class="text-muted small">البداية الفعلية</td>
                                    <td class="text-end small text-success">@Model.Step.ActualStartDate.Value.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                            @if (Model.Step.ActualEndDate.HasValue)
                            {
                                <tr>
                                    <td class="text-muted small">النهاية الفعلية</td>
                                    <td class="text-end small @(Model.IsDelayed ? "text-danger fw-bold" : "text-success")">
                                        @Model.Step.ActualEndDate.Value.ToString("yyyy-MM-dd")
                                        @if (Model.IsDelayed)
                                        {
                                            <i class="bi bi-exclamation-triangle ms-1"></i>
                                        }
                                    </td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>

                <!-- مؤشرات الأداء -->
                @if (Model.Step.KPIs?.Any() == true)
                {
                    <div class="card mb-3">
                        <div class="card-header"><i class="bi bi-graph-up me-2"></i>مؤشرات الأداء</div>
                        <div class="card-body py-2">
                            <ul class="list-unstyled mb-0">
                                @foreach (var kpi in Model.Step.KPIs.OrderBy(k => k.OrderIndex))
                                {
                                    <li class="py-1 border-bottom">
                                        <i class="bi bi-check2 text-primary me-1"></i>
                                        <span class="small">@kpi.Indicator</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <!-- الجهات المساندة -->
                @if (Model.Step.StepSupportingUnits?.Any() == true)
                {
                    <div class="card mb-3">
                        <div class="card-header"><i class="bi bi-building me-2"></i>الجهات المساندة</div>
                        <div class="card-body py-2">
                            @foreach (var su in Model.Step.StepSupportingUnits)
                            {
                                <div class="py-1 border-bottom small">
                                    <i class="bi bi-building text-info me-1"></i>@(su.ProjectSupportingUnit?.ExternalUnitName ?? "-")
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="card">
                    <div class="card-body py-2">
                        <small class="text-muted d-block">
                            <strong>أنشئ بواسطة:</strong> @(Model.Step.CreatedBy?.FullNameAr ?? "—")
                        </small>
                        <small class="text-muted d-block mt-1">
                            <strong>تاريخ الإنشاء:</strong> @Model.Step.CreatedAt.ToString("yyyy-MM-dd")
                        </small>
                        @if (Model.Step.LastModifiedAt.HasValue)
                        {
                            <small class="text-muted d-block mt-1">
                                <strong>آخر تعديل:</strong> @Model.Step.LastModifiedAt.Value.ToString("yyyy-MM-dd")
                            </small>
                        }
                    </div>
                </div>

                @if (Model.Step.TeamMembers != null && Model.Step.TeamMembers.Any())
                {
                    <div class="card mt-3">
                        <div class="card-header">
                            <i class="bi bi-people me-2"></i>فريق العمل
                            <span class="badge bg-secondary ms-2">@Model.Step.TeamMembers.Count</span>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>العضو</th>
                                        <th>الرقم</th>
                                        <th>الدور</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var member in Model.Step.TeamMembers.OrderBy(m => m.OrderIndex))
                                    {
                                        <tr>
                                            <td>
                                                <i class="bi bi-person me-1 text-muted"></i>
                                                <strong>@member.FullName</strong>
                                            </td>
                                            <td><small class="text-muted">@member.EmpNumber</small></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(member.Role))
                                                {
                                                    <span class="badge bg-info bg-opacity-25 text-info">@member.Role</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- تبويب التوثيق -->
    @if (hasDocumentation)
    {
        <div class="tab-pane fade" id="pane-docs" role="tabpanel">
            <div class="row g-4">
                @if (!string.IsNullOrEmpty(Model.Step.CompletionDetails) || !string.IsNullOrEmpty(Model.Step.ApproverNotes))
                {
                    <div class="col-lg-6">
                        @if (!string.IsNullOrEmpty(Model.Step.CompletionDetails))
                        {
                            <div class="card mb-3">
                                <div class="card-header"><i class="bi bi-chat-left-text me-2"></i>ملاحظة المنفذ</div>
                                <div class="card-body"><p class="mb-0">@Model.Step.CompletionDetails</p></div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Step.ApproverNotes))
                        {
                            <div class="card border-success">
                                <div class="card-header bg-success bg-opacity-10">
                                    <i class="bi bi-person-check me-2 text-success"></i>ملاحظة المؤكد
                                </div>
                                <div class="card-body">
                                    <p class="mb-0">@Model.Step.ApproverNotes</p>
                                    @if (Model.Step.ApprovedBy != null)
                                    {
                                        <hr class="my-2">
                                        <small class="text-muted">
                                            <i class="bi bi-check-circle text-success me-1"></i>
                                            @Model.Step.ApprovedBy.FullNameAr —
                                            @Model.Step.ApprovedAt?.ToString("yyyy/MM/dd")
                                        </small>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                @{
                    var submittedAt = Model.Step.SubmittedForApprovalAt;
                    var allAttachments = Model.Step.Attachments ?? new List<StepAttachment>();
                    var latestAttachments = submittedAt.HasValue
                        ? allAttachments.Where(a => a.UploadedAt >= submittedAt.Value.AddMinutes(-1)).OrderByDescending(a => a.UploadedAt).ToList()
                        : allAttachments.OrderByDescending(a => a.UploadedAt).ToList();
                    var olderAttachments = submittedAt.HasValue
                        ? allAttachments.Where(a => a.UploadedAt < submittedAt.Value.AddMinutes(-1)).OrderByDescending(a => a.UploadedAt).ToList()
                        : new List<StepAttachment>();
                }
                @if (allAttachments.Any())
                {
                    <div class="col-lg-6">
                        <div class="card">
                            <div class="card-header">
                                <i class="bi bi-paperclip me-2"></i>المرفقات (@Model.Step.Attachments.Count)
                            </div>
                            <div class="card-body">
                                @* === المرفقات الحالية (الأحدث) === *@
                                @foreach (var attachment in latestAttachments)
                                {
                                    var isPdf = attachment.ContentType.Contains("pdf");
                                    <div class="d-flex align-items-center justify-content-between p-2 border rounded mb-2 border-primary bg-primary bg-opacity-10">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi @(isPdf ? "bi-file-pdf text-danger" : "bi-file-image text-success") fs-5"></i>
                                            <div>
                                                <div class="small fw-bold">
                                                    @attachment.OriginalFileName
                                                    <span class="badge bg-primary ms-1" style="font-size:.65rem;">جديد</span>
                                                </div>
                                                <div class="text-muted" style="font-size:0.75rem;">
                                                    @(attachment.FileSize / 1024) KB — @attachment.UploadedAt.ToString("yyyy/MM/dd HH:mm")
                                                </div>
                                            </div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                data-bs-toggle="modal" data-bs-target="#attachmentModal_@attachment.Id">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                    @await Html.PartialAsync("_AttachmentModal", attachment)
                                }

                                @* === المرفقات السابقة (مخفية) === *@
                                @if (olderAttachments.Any())
                                {
                                    <div class="mt-2">
                                        <button class="btn btn-sm btn-outline-secondary w-100" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#olderAttachments">
                                            <i class="bi bi-clock-history me-1"></i>مرفقات سابقة (@olderAttachments.Count)
                                            <i class="bi bi-chevron-down ms-1"></i>
                                        </button>
                                        <div class="collapse mt-2" id="olderAttachments">
                                            @foreach (var attachment in olderAttachments)
                                            {
                                                var isPdf = attachment.ContentType.Contains("pdf");
                                                <div class="d-flex align-items-center justify-content-between p-2 border rounded mb-2" style="opacity:.7;">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <i class="bi @(isPdf ? "bi-file-pdf text-danger" : "bi-file-image text-success") fs-5"></i>
                                                        <div>
                                                            <div class="small fw-bold">@attachment.OriginalFileName</div>
                                                            <div class="text-muted" style="font-size:0.75rem;">
                                                                @(attachment.FileSize / 1024) KB — @attachment.UploadedAt.ToString("yyyy/MM/dd HH:mm")
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                                            data-bs-toggle="modal" data-bs-target="#attachmentModal_@attachment.Id">
                                                        <i class="bi bi-eye"></i>
                                                    </button>
                                                </div>
                                                @await Html.PartialAsync("_AttachmentModal", attachment)
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- تبويب الإجراءات -->
    @if (canEdit && !isApproved && !isPendingApproval)
    {
        <div class="tab-pane fade" id="pane-actions" role="tabpanel">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card border-success">
                        <div class="card-header bg-success text-white">
                            <i class="bi bi-graph-up me-2"></i>تحديث نسبة الإنجاز
                        </div>
                        <div class="card-body">
                            <form asp-action="UpdateProgress" asp-controller="Steps" method="post">
                                <input type="hidden" name="id" value="@Model.Step.Id" />
                                <div class="mb-3">
                                    <label class="form-label">النسبة الجديدة</label>
                                    <div class="input-group">
                                        <input type="number" name="progress" class="form-control"
                                               value="@((int)Model.Step.ProgressPercentage)" min="0" max="99" step="1" />
                                        <span class="input-group-text">%</span>
                                    </div>
                                    <small class="text-muted">للوصول لـ 100% استخدم "إرسال للتأكيد"</small>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">ملاحظات <span class="text-muted">(اختياري)</span></label>
                                    <textarea name="notes" class="form-control" rows="2" placeholder="سبب التحديث..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="bi bi-check me-2"></i>تحديث النسبة
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card border-primary">
                        <div class="card-header bg-primary text-white">
                            <i class="bi bi-send me-2"></i>إرسال للتأكيد
                        </div>
                        <div class="card-body">
                            @if (isRejected)
                            {
                                <div class="alert alert-danger py-2 mb-3">
                                    <small><i class="bi bi-exclamation-circle me-1"></i>تم رفض الخطوة التنفيذية — يمكنك إعادة إرسالها بعد التعديل</small>
                                </div>
                            }
                            <form asp-action="SubmitForApproval" asp-controller="Steps" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="id" value="@Model.Step.Id" />
                                <div class="mb-3">
                                    <label class="form-label">تفاصيل الإتمام <span class="text-muted">(اختياري)</span></label>
                                    <textarea name="completionDetails" class="form-control" rows="3"
                                              placeholder="ماذا أنجزت في هذه الخطوة التنفيذية..."></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">مرفق توثيقي <span class="text-muted">(اختياري)</span></label>
                                    <input type="file" name="attachmentFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                                    <small class="text-muted">PDF أو صورة — حد أقصى 10 MB</small>
                                </div>
                                <div class="alert alert-info py-2 mb-3">
                                    <small>
                                        <i class="bi bi-info-circle me-1"></i>
                                        بعد الإرسال تنتقل الخطوة التنفيذية لمؤكد الخطوات للمراجعة
                                    </small>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-send me-2"></i>إرسال للتأكيد
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- تبويب السجل -->
    @if (canSeeHistory)
    {
        <div class="tab-pane fade" id="pane-history" role="tabpanel">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-journal-text me-2"></i>سجل الملاحظات والتحديثات</span>
                    <span class="badge bg-secondary">@Model.Notes.Count</span>
                </div>
                <div class="card-body">
                    @if (Model.Notes.Any())
                    {
                        @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt))
                        {
                            var isProgressUpdate = note.UpdateType == UpdateType.StatusChange;
                            var isNoteType = note.UpdateType == UpdateType.Note;
                            <div class="d-flex gap-3 mb-3 pb-3 border-bottom">
                                <div class="flex-shrink-0">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center @(isProgressUpdate ? "bg-success" : "bg-secondary") text-white"
                                         style="width:32px;height:32px;">
                                        <i class="bi @(isProgressUpdate ? "bi-graph-up-arrow" : "bi-chat-left-text") small"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong class="small">@note.CreatedBy?.FullNameAr</strong>
                                            @if (isProgressUpdate)
                                            {
                                                <span class="badge bg-success ms-2 small">
                                                    @((int)note.PreviousPercentage)% ← @((int)note.ProgressPercentage)%
                                                </span>
                                            }
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <small class="text-muted">@note.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                            @if (isAdmin && isNoteType)
                                            {
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1"
                                                            onclick="editNote(@note.Id, '@Html.Raw(note.NotesAr?.Replace("'", "\\'").Replace("\r\n", "\\n").Replace("\n", "\\n"))')"
                                                            title="تعديل">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1"
                                                            onclick="deleteNote(@note.Id)" title="حذف">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(note.NotesAr))
                                    {
                                        <p class="mb-0 mt-1 small text-muted">@note.NotesAr</p>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-journal-x fs-3 d-block mb-2"></i>
                            لا توجد ملاحظات أو تحديثات بعد
                        </div>
                    }
                </div>
            </div>
            @if (isAdmin)
            {
                <div class="card mt-3">
                    <div class="card-header"><i class="bi bi-plus-circle me-2"></i>إضافة ملاحظة</div>
                    <div class="card-body">
                        <form asp-action="AddNote" asp-controller="Steps" method="post">
                            <input type="hidden" name="id" value="@Model.Step.Id" />
                            <div class="input-group">
                                <textarea name="notes" class="form-control" rows="2" placeholder="أضف ملاحظة أو تحديث..." required></textarea>
                                <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i></button>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>
    }

</div>

<!-- Modals التأكيد والرفض -->
@if (isStepApprover && isPendingApproval)
{
    <div class="modal fade" id="approveStepModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="ApproveStep" asp-route-id="@Model.Step.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title"><i class="bi bi-check-circle me-2"></i>تأكيد الخطوة التنفيذية</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(Model.Step.CompletionDetails))
                        {
                            <div class="alert alert-info mb-3">
                                <small class="text-muted d-block mb-1"><i class="bi bi-chat-left-text me-1"></i>ملاحظة المنفذ:</small>
                                @Model.Step.CompletionDetails
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label">ملاحظة المؤكد <span class="text-muted">(اختياري)</span></label>
                            <textarea name="approverNotes" class="form-control" rows="3" placeholder="أضف ملاحظة للمنفذ عند التأكيد..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>تأكيد الخطوة التنفيذية</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="rejectStepModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="RejectStep" asp-route-id="@Model.Step.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title"><i class="bi bi-x-circle me-2"></i>رفض الخطوة التنفيذية</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-3"><strong>الخطوة التنفيذية:</strong> @Model.Step.NameAr</p>
                        <div class="mb-3">
                            <label class="form-label">سبب الرفض <span class="text-danger">*</span></label>
                            <textarea name="rejectionReason" class="form-control" rows="4" required
                                      placeholder="اكتب سبب رفض الخطوة التنفيذية بالتفصيل..."></textarea>
                            <small class="text-muted">سيتم إرسال هذا السبب لمسؤول الخطوة التنفيذية</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-x-lg me-1"></i>تأكيد الرفض</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (isAdmin)
{
    <div class="modal fade" id="editNoteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="EditNote" asp-controller="Steps" method="post">
                    <input type="hidden" name="noteId" id="editNoteId" />
                    <input type="hidden" name="stepId" value="@Model.Step.Id" />
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>تعديل الملاحظة</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <textarea name="notes" id="editNoteText" class="form-control" rows="4" required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteNoteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="DeleteNote" asp-controller="Steps" method="post">
                    <input type="hidden" name="noteId" id="deleteNoteId" />
                    <input type="hidden" name="stepId" value="@Model.Step.Id" />
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title"><i class="bi bi-trash me-2"></i>حذف الملاحظة</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>هل أنت متأكد من حذف هذه الملاحظة؟</p>
                        <p class="text-danger"><small>هذا الإجراء لا يمكن التراجع عنه.</small></p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-danger">حذف</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        @if (isRejected && canEdit)
        {
                <text>
                document.addEventListener('DOMContentLoaded', function () {
                    var tabEl = document.getElementById('tab-actions');
                    if (tabEl) new bootstrap.Tab(tabEl).show();
                });
                </text>
        }

        function editNote(noteId, noteText) {
            document.getElementById('editNoteId').value = noteId;
            document.getElementById('editNoteText').value = noteText;
            new bootstrap.Modal(document.getElementById('editNoteModal')).show();
        }

        function deleteNote(noteId) {
            document.getElementById('deleteNoteId').value = noteId;
            new bootstrap.Modal(document.getElementById('deleteNoteModal')).show();
        }
    </script>
}

@model OperationalPlanMS.Models.ViewModels.FinancialCostFormViewModel
@{
    ViewData["Title"] = "تعديل التكلفة المالية";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">تعديل التكلفة المالية</h4>
        <p class="text-muted mb-0">@Model.NameAr</p>
    </div>
    <a href="/StrategicPlanning/FinancialCosts" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header text-white" style="background-color: #20c997;">
                <i class="bi bi-cash-stack me-2"></i>بيانات التكلفة المالية
            </div>
            <div class="card-body">
                <form asp-action="EditFinancialCost" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NameAr" class="form-label">اسم التكلفة بالعربية <span class="text-danger">*</span></label>
                            <input asp-for="NameAr" class="form-control" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="NameEn" class="form-label">اسم التكلفة بالإنجليزية <span class="text-danger">*</span></label>
                            <input asp-for="NameEn" class="form-control" dir="ltr" />
                            <span asp-validation-for="NameEn" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DescriptionAr" class="form-label">الوصف بالعربية</label>
                            <textarea asp-for="DescriptionAr" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DescriptionEn" class="form-label">الوصف بالإنجليزية</label>
                            <textarea asp-for="DescriptionEn" class="form-control" rows="3" dir="ltr"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="OrderIndex" class="form-label">الترتيب</label>
                            <input asp-for="OrderIndex" type="number" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label">نشط</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a href="/StrategicPlanning/FinancialCosts" class="btn btn-secondary">إلغاء</a>
                        <button type="submit" class="btn text-white" style="background-color: #20c997;">
                            <i class="bi bi-check-lg me-2"></i>حفظ التعديلات
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

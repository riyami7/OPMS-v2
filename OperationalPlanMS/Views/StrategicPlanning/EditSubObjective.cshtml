@model OperationalPlanMS.Models.ViewModels.SubObjectiveFormViewModel
@{
    ViewData["Title"] = "تعديل الهدف الفرعي";
}

<style>
    .cascade-select {
        transition: all 0.3s;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">تعديل الهدف الفرعي</h4>
        <p class="text-muted mb-0">@Model.NameAr</p>
    </div>
    <a href="/StrategicPlanning" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header bg-info text-white">
                <i class="bi bi-flag-fill me-2"></i>بيانات الهدف الفرعي
            </div>
            <div class="card-body">
                <form asp-action="EditSubObjective" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MainObjectiveId" class="form-label"></label>
                            <select asp-for="MainObjectiveId" asp-items="Model.MainObjectives" class="form-select">
                                <option value="">-- اختر الهدف الرئيسي --</option>
                            </select>
                            <span asp-validation-for="MainObjectiveId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <!-- فارغ للتوازن -->
                        </div>

                        <!-- الهيكل التنظيمي من API -->
                        <div class="col-12 mb-3">
                            <label class="form-label"><i class="bi bi-diagram-3 me-1"></i>الوحدة التنظيمية</label>
                            <div id="editSubOrgTree"></div>
                            <input type="hidden" asp-for="ExternalUnitId" id="ExternalUnitId" />
                            <input type="hidden" asp-for="ExternalUnitName" id="ExternalUnitName" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="NameAr" class="form-label"></label>
                            <input asp-for="NameAr" class="form-control" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="NameEn" class="form-label"></label>
                            <input asp-for="NameEn" class="form-control" dir="ltr" />
                            <span asp-validation-for="NameEn" ></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DescriptionAr" class="form-label"></label>
                            <textarea asp-for="DescriptionAr" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DescriptionEn" class="form-label"></label>
                            <textarea asp-for="DescriptionEn" class="form-control" rows="3" dir="ltr"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="OrderIndex" class="form-label"></label>
                            <input asp-for="OrderIndex" type="number" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a href="/StrategicPlanning" class="btn btn-secondary">إلغاء</a>
                        <button type="submit" class="btn btn-info text-white">
                            <i class="bi bi-check-lg me-2"></i>حفظ التعديلات
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            OrgTreePicker.init({
                containerId: 'editSubOrgTree',
                hiddenInputId: 'ExternalUnitId',
                hiddenNameId: 'ExternalUnitName',
                selectedId: '@(Model.ExternalUnitId?.ToString() ?? "")',
                rootCode: '00001'
            });
        });
    </script>
}

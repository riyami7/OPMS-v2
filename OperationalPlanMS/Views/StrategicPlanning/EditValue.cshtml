@model OperationalPlanMS.Models.ViewModels.CoreValueFormViewModel
@{
    ViewData["Title"] = "تعديل القيمة";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">تعديل القيمة</h4>
        <p class="text-muted mb-0">@Model.NameAr</p>
    </div>
    <a href="/StrategicPlanning" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-heart me-2"></i>بيانات القيمة
            </div>
            <div class="card-body">
                <form asp-action="EditValue" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NameAr" class="form-label"></label>
                            <input asp-for="NameAr" class="form-control" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="NameEn" class="form-label"></label>
                            <input asp-for="NameEn" class="form-control" dir="ltr" />
                            <span asp-validation-for="NameEn" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="MeaningAr" class="form-label"></label>
                            <textarea asp-for="MeaningAr" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="MeaningEn" class="form-label"></label>
                            <textarea asp-for="MeaningEn" class="form-control" rows="3" dir="ltr"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Icon" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi @(Model.Icon ?? "bi-heart-fill")"></i>
                                </span>
                                <input asp-for="Icon" class="form-control" dir="ltr" placeholder="bi-heart-fill" />
                            </div>
                            <small class="text-muted">اختر من <a href="https://icons.getbootstrap.com/" target="_blank">Bootstrap Icons</a></small>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="OrderIndex" class="form-label"></label>
                            <input asp-for="OrderIndex" type="number" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a href="/StrategicPlanning" class="btn btn-secondary">إلغاء</a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-check-lg me-2"></i>حفظ التعديلات
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

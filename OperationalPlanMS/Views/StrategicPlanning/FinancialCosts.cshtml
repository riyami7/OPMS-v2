@model List<OperationalPlanMS.Models.Entities.FinancialCost>
@{
    ViewData["Title"] = "التكلفة المالية";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">التكلفة المالية</h4>
        <p class="text-muted mb-0">إدارة أنواع التكاليف المالية</p>
    </div>
    <div>
        <a href="/Admin" class="btn btn-outline-secondary me-2">
            <i class="bi bi-arrow-right me-2"></i>رجوع
        </a>
        <button type="button" class="btn text-white" style="background-color: #20c997;" data-bs-toggle="modal" data-bs-target="#addCostModal">
            <i class="bi bi-plus me-2"></i>إضافة تكلفة
        </button>
    </div>
</div>

<div class="card">
    <div class="card-header" style="background-color: #20c997; color: white;">
        <i class="bi bi-cash-stack me-2"></i>أنواع التكلفة المالية
        <span class="badge bg-light text-dark ms-2">@Model.Count</span>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th width="60">#</th>
                            <th>اسم التكلفة</th>
                            <th>الوصف</th>
                            <th width="80">الترتيب</th>
                            <th width="80">الحالة</th>
                            <th width="120">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cost in Model.OrderBy(c => c.OrderIndex))
                        {
                            <tr>
                                <td><span class="badge" style="background-color: #20c997;">@cost.Id</span></td>
                                <td>
                                    <strong>@cost.NameAr</strong>
                                    <br><small class="text-muted" dir="ltr">@cost.NameEn</small>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(cost.DescriptionAr))
                                    {
                                        <span class="text-truncate d-inline-block" style="max-width: 300px;" title="@cost.DescriptionAr">
                                            @cost.DescriptionAr
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@cost.OrderIndex</td>
                                <td>
                                    @if (cost.IsActive)
                                    {
                                        <span class="badge bg-success">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">معطل</span>
                                    }
                                </td>
                                <td>
                                    <a href="/StrategicPlanning/EditFinancialCost/@cost.Id" class="btn btn-sm btn-outline-primary" title="تعديل">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleFinancialCost" asp-route-id="@cost.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(cost.IsActive ? "btn-outline-warning" : "btn-outline-success")" 
                                                title="@(cost.IsActive ? "تعطيل" : "تفعيل")">
                                            <i class="bi @(cost.IsActive ? "bi-pause" : "bi-play")"></i>
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-outline-danger" 
                                            onclick="confirmDelete(@cost.Id, '@cost.NameAr')" title="حذف">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-cash-stack text-muted" style="font-size: 4rem;"></i>
                <h5 class="mt-3">لا توجد تكاليف مالية</h5>
                <p class="text-muted">اضغط على "إضافة تكلفة" لإضافة نوع تكلفة جديد</p>
            </div>
        }
    </div>
</div>

<!-- Modal إضافة تكلفة -->
<div class="modal fade" id="addCostModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddFinancialCost" method="post">
                <div class="modal-header text-white" style="background-color: #20c997;">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>إضافة تكلفة مالية</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">اسم التكلفة بالعربية <span class="text-danger">*</span></label>
                        <input type="text" name="NameAr" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">اسم التكلفة بالإنجليزية <span class="text-danger">*</span></label>
                        <input type="text" name="NameEn" class="form-control" dir="ltr" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الوصف بالعربية</label>
                        <textarea name="DescriptionAr" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الوصف بالإنجليزية</label>
                        <textarea name="DescriptionEn" class="form-control" rows="3" dir="ltr"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <label class="form-label">الترتيب</label>
                            <input type="number" name="OrderIndex" class="form-control" value="0" />
                        </div>
                        <div class="col-6 d-flex align-items-end">
                            <div class="form-check">
                                <input type="checkbox" name="IsActive" value="true" class="form-check-input" checked />
                                <label class="form-check-label">نشط</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn text-white" style="background-color: #20c997;">
                        <i class="bi bi-check-lg me-1"></i>حفظ
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal تأكيد الحذف -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="deleteForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>تأكيد الحذف</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>هل أنت متأكد من حذف التكلفة: <strong id="deleteName"></strong>؟</p>
                    <p class="text-danger small">هذا الإجراء لا يمكن التراجع عنه.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>حذف</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('deleteName').textContent = name;
            document.getElementById('deleteForm').action = '/StrategicPlanning/DeleteFinancialCost/' + id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}

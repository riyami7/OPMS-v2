@model OperationalPlanMS.Models.ViewModels.StrategicPlanningViewModel
@{
    ViewData["Title"] = "التخطيط الاستراتيجي";
}

<style>
    .cascade-select {
        transition: all 0.3s;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">التخطيط الاستراتيجي</h4>
        <p class="text-muted mb-0">إدارة المحاور والأهداف الاستراتيجية والرئيسية والفرعية والقيم</p>
    </div>
    <a href="/Admin" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع
    </a>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" id="strategicTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="axes-tab" data-bs-toggle="tab" data-bs-target="#axes" type="button">
            <i class="bi bi-bullseye me-2"></i>المحاور
            <span class="badge bg-secondary ms-1">@Model.Axes.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="strategic-objectives-tab" data-bs-toggle="tab" data-bs-target="#strategic-objectives" type="button">
            <i class="bi bi-star me-2"></i>الأهداف الاستراتيجية
            <span class="badge bg-primary ms-1">@Model.StrategicObjectives.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="main-objectives-tab" data-bs-toggle="tab" data-bs-target="#main-objectives" type="button">
            <i class="bi bi-flag me-2"></i>الأهداف الرئيسية
            <span class="badge bg-success ms-1">@Model.MainObjectives.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="sub-objectives-tab" data-bs-toggle="tab" data-bs-target="#sub-objectives" type="button">
            <i class="bi bi-flag-fill me-2"></i>الأهداف الفرعية
            <span class="badge bg-info ms-1">@Model.SubObjectives.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="values-tab" data-bs-toggle="tab" data-bs-target="#values" type="button">
            <i class="bi bi-vignette me-2"></i>القيم
            <span class="badge bg-danger ms-1">@Model.CoreValues.Count</span>
        </button>
    </li>
</ul>

<div class="tab-content" id="strategicTabsContent">
    <!-- المحاور الرئيسية -->
    <div class="tab-pane fade show active" id="axes" role="tabpanel">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-bullseye me-2"></i>المحاور الرئيسية</span>
                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addAxisModal">
                    <i class="bi bi-plus me-1"></i>إضافة محور
                </button>
            </div>
            <div class="card-body">
                @if (Model.Axes.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th width="80">الكود</th>
                                    <th>المحور</th>
                                    <th>الوصف</th>
                                    <th width="140">الأهداف الاستراتيجية</th>
                                    <th width="80">الترتيب</th>
                                    <th width="80">الحالة</th>
                                    <th width="100">إجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var axis in Model.Axes.OrderBy(a => a.OrderIndex))
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary">@axis.Code</span></td>
                                        <td>
                                            <strong>@axis.NameAr</strong>
                                            <br><small class="text-muted" dir="ltr">@axis.NameEn</small>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(axis.DescriptionAr))
                                            {
                                                <span class="text-truncate d-inline-block" style="max-width: 200px;">@axis.DescriptionAr</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-primary">@axis.StrategicObjectives.Count هدف</span></td>
                                        <td>@axis.OrderIndex</td>
                                        <td>
                                            @if (axis.IsActive)
                                            {
                                                <span class="badge bg-success">نشط</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">معطل</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="/StrategicPlanning/EditAxis/@axis.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete('Axis', @axis.Id, '@axis.NameAr')"><i class="bi bi-trash"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-bullseye text-muted" style="font-size: 4rem;"></i>
                        <h5 class="mt-3">لا توجد محاور</h5>
                        <p class="text-muted">اضغط على "إضافة محور" لإضافة محور جديد</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- الأهداف الاستراتيجية -->
    <div class="tab-pane fade" id="strategic-objectives" role="tabpanel">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-star me-2"></i>الأهداف الاستراتيجية</span>
                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addStrategicObjectiveModal"
                @(Model.Axes.Any() ? "" : "disabled")>
                    <i class="bi bi-plus me-1"></i>إضافة هدف استراتيجي
                </button>
            </div>
            <div class="card-body">
                @if (Model.StrategicObjectives.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th width="80">الكود</th>
                                    <th>الهدف الاستراتيجي</th>
                                    <th>المحور</th>
                                    <th width="120">الأهداف الرئيسية</th>
                                    <th width="80">الترتيب</th>
                                    <th width="80">الحالة</th>
                                    <th width="100">إجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var obj in Model.StrategicObjectives.OrderBy(o => o.StrategicAxis.OrderIndex).ThenBy(o => o.OrderIndex))
                                {
                                    <tr>
                                        <td><span class="badge bg-primary">@obj.Code</span></td>
                                        <td>
                                            <strong>@obj.NameAr</strong>
                                            <br><small class="text-muted" dir="ltr">@obj.NameEn</small>
                                        </td>
                                        <td><span class="badge bg-secondary">@obj.StrategicAxis?.NameAr</span></td>
                                        <td><span class="badge bg-success">@obj.MainObjectives.Count هدف</span></td>
                                        <td>@obj.OrderIndex</td>
                                        <td>
                                            @if (obj.IsActive)
                                            {
                                                <span class="badge bg-success">نشط</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">معطل</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="/StrategicPlanning/EditStrategicObjective/@obj.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete('StrategicObjective', @obj.Id, '@obj.NameAr')"><i class="bi bi-trash"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-star text-muted" style="font-size: 4rem;"></i>
                        <h5 class="mt-3">لا توجد أهداف استراتيجية</h5>
                        @if (!Model.Axes.Any())
                        {
                            <p class="text-muted">يجب إضافة محور أولاً</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- الأهداف الرئيسية -->
    <div class="tab-pane fade" id="main-objectives" role="tabpanel">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-flag me-2"></i>الأهداف الرئيسية</span>
                <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#addMainObjectiveModal"
                @(Model.StrategicObjectives.Any() ? "" : "disabled")>
                    <i class="bi bi-plus me-1"></i>إضافة هدف رئيسي
                </button>
            </div>
            <div class="card-body">
                @if (Model.MainObjectives.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th width="80">الكود</th>
                                    <th>الهدف الرئيسي</th>
                                    <th>الهدف الاستراتيجي</th>
                                    <th width="120">الأهداف الفرعية</th>
                                    <th width="80">الترتيب</th>
                                    <th width="80">الحالة</th>
                                    <th width="100">إجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var obj in Model.MainObjectives.OrderBy(o => o.StrategicObjective.OrderIndex).ThenBy(o => o.OrderIndex))
                                {
                                    <tr>
                                        <td><span class="badge bg-success">@obj.Code</span></td>
                                        <td>
                                            <strong>@obj.NameAr</strong>
                                            <br><small class="text-muted" dir="ltr">@obj.NameEn</small>
                                        </td>
                                        <td><span class="badge bg-primary">@obj.StrategicObjective?.NameAr</span></td>
                                        <td><span class="badge bg-info">@obj.SubObjectives.Count فرعي</span></td>
                                        <td>@obj.OrderIndex</td>
                                        <td>
                                            @if (obj.IsActive)
                                            {
                                                <span class="badge bg-success">نشط</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">معطل</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="/StrategicPlanning/EditMainObjective/@obj.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete('MainObjective', @obj.Id, '@obj.NameAr')"><i class="bi bi-trash"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-flag text-muted" style="font-size: 4rem;"></i>
                        <h5 class="mt-3">لا توجد أهداف رئيسية</h5>
                        @if (!Model.StrategicObjectives.Any())
                        {
                            <p class="text-muted">يجب إضافة هدف استراتيجي أولاً</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- الأهداف الفرعية -->
    <div class="tab-pane fade" id="sub-objectives" role="tabpanel">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-flag-fill me-2"></i>الأهداف الفرعية</span>
                <button type="button" class="btn btn-info btn-sm text-white" data-bs-toggle="modal" data-bs-target="#addSubObjectiveModal"
                @(Model.MainObjectives.Any() ? "" : "disabled")>
                    <i class="bi bi-plus me-1"></i>إضافة هدف فرعي
                </button>
            </div>
            <div class="card-body">
                @if (Model.SubObjectives.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th width="80">الكود</th>
                                    <th>الهدف الفرعي</th>
                                    <th>الهدف الرئيسي</th>
                                    <th>الوحدة التنظيمية</th>
                                    <th width="80">الترتيب</th>
                                    <th width="80">الحالة</th>
                                    <th width="100">إجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var obj in Model.SubObjectives.OrderBy(o => o.MainObjective.OrderIndex).ThenBy(o => o.OrderIndex))
                                {
                                    <tr>
                                        <td><span class="badge bg-info">@obj.Code</span></td>
                                        <td>
                                            <strong>@obj.NameAr</strong>
                                            <br><small class="text-muted" dir="ltr">@obj.NameEn</small>
                                        </td>
                                        <td><span class="badge bg-success">@obj.MainObjective?.NameAr</span></td>
                                        <td><span class="badge bg-secondary">@obj.UnitDisplayName</span></td>
                                        <td>@obj.OrderIndex</td>
                                        <td>
                                            @if (obj.IsActive)
                                            {
                                                <span class="badge bg-success">نشط</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">معطل</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="/StrategicPlanning/EditSubObjective/@obj.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete('SubObjective', @obj.Id, '@obj.NameAr')"><i class="bi bi-trash"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-flag-fill text-muted" style="font-size: 4rem;"></i>
                        <h5 class="mt-3">لا توجد أهداف فرعية</h5>
                        @if (!Model.MainObjectives.Any())
                        {
                            <p class="text-muted">يجب إضافة هدف رئيسي أولاً</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- القيم -->
    <div class="tab-pane fade" id="values" role="tabpanel">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-vignette me-2"></i>القيم المؤسسية</span>
                <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#addValueModal">
                    <i class="bi bi-plus me-1"></i>إضافة قيمة
                </button>
            </div>
            <div class="card-body">
                @if (Model.CoreValues.Any())
                {
                    <div class="row">
                        @foreach (var value in Model.CoreValues.OrderBy(v => v.OrderIndex))
                        {
                            <div class="col-md-4 mb-3">
                                <div class="card h-100 @(value.IsActive ? "" : "bg-light")">
                                    <div class="card-body text-center">
                                        <i class="bi @(value.Icon ?? "bi-vignette-fill") text-danger" style="font-size: 2.5rem;"></i>
                                        <h5 class="card-title mt-2">@value.NameAr</h5>
                                        <p class="card-text small text-muted" dir="ltr">@value.NameEn</p>
                                        @if (!string.IsNullOrEmpty(value.MeaningAr))
                                        {
                                            <p class="card-text">@value.MeaningAr</p>
                                        }
                                        @if (!value.IsActive)
                                        {
                                            <span class="badge bg-secondary">معطل</span>
                                        }
                                    </div>
                                    <div class="card-footer bg-transparent text-center">
                                        <a href="/StrategicPlanning/EditValue/@value.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete('Value', @value.Id, '@value.NameAr')"><i class="bi bi-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-vignette text-muted" style="font-size: 4rem;"></i>
                        <h5 class="mt-3">لا توجد قيم</h5>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal إضافة محور -->
<div class="modal fade" id="addAxisModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddAxis" method="post">
                <div class="modal-header bg-secondary text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>إضافة محور</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">الاسم بالعربية <span class="text-danger">*</span></label>
                        <input type="text" name="NameAr" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الاسم بالإنجليزية </label>
                        <input type="text" name="NameEn" class="form-control" dir="ltr" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الوصف</label>
                        <textarea name="DescriptionAr" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <label class="form-label">الترتيب</label>
                            <input type="number" name="OrderIndex" class="form-control" value="0" />
                        </div>
                        <div class="col-6 d-flex align-items-end">
                            <div class="form-check">
                                <input type="checkbox" name="IsActive" value="true" class="form-check-input" checked />
                                <label class="form-check-label">نشط</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>حفظ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal إضافة هدف استراتيجي -->
<div class="modal fade" id="addStrategicObjectiveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddStrategicObjective" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>إضافة هدف استراتيجي</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">المحور <span class="text-danger">*</span></label>
                        <select name="StrategicAxisId" class="form-select" required>
                            <option value="">-- اختر المحور --</option>
                            @foreach (var axis in Model.Axes.Where(a => a.IsActive))
                            {
                                <option value="@axis.Id">@axis.NameAr</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الاسم بالعربية <span class="text-danger">*</span></label>
                        <input type="text" name="NameAr" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الاسم بالإنجليزية</label>
                        <input type="text" name="NameEn" class="form-control" dir="ltr" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الوصف</label>
                        <textarea name="DescriptionAr" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <label class="form-label">الترتيب</label>
                            <input type="number" name="OrderIndex" class="form-control" value="0" />
                        </div>
                        <div class="col-6 d-flex align-items-end">
                            <div class="form-check">
                                <input type="checkbox" name="IsActive" value="true" class="form-check-input" checked />
                                <label class="form-check-label">نشط</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>حفظ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal إضافة هدف رئيسي -->
<div class="modal fade" id="addMainObjectiveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddMainObjective" method="post">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>إضافة هدف رئيسي</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">الهدف الاستراتيجي <span class="text-danger">*</span></label>
                        <select name="StrategicObjectiveId" class="form-select" required>
                            <option value="">-- اختر الهدف الاستراتيجي --</option>
                            @foreach (var obj in Model.StrategicObjectives.Where(o => o.IsActive))
                            {
                                <option value="@obj.Id">@obj.StrategicAxis?.NameAr - @obj.NameAr</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الاسم بالعربية <span class="text-danger">*</span></label>
                        <input type="text" name="NameAr" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الاسم بالإنجليزية</label>
                        <input type="text" name="NameEn" class="form-control" dir="ltr" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الوصف</label>
                        <textarea name="DescriptionAr" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <label class="form-label">الترتيب</label>
                            <input type="number" name="OrderIndex" class="form-control" value="0" />
                        </div>
                        <div class="col-6 d-flex align-items-end">
                            <div class="form-check">

                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let allUnits = [];

        // تحميل الوحدات عند فتح الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            loadOrganizationalUnits();
        });

        // تحميل كل الوحدات من API
        async function loadOrganizationalUnits() {
            try {
                const response = await fetch('/api/OrganizationApi/units/all');
                if (response.ok) {
                    const data = await response.json();
                    allUnits = data.items || data;

                }
            } catch (error) {
                console.error('Error loading units:', error);
            }
        }

        // شجرة الوحدات للـ Modal
        function initAddSubOrgTree() {
            OrgTreePicker.init({
                containerId: 'addSubOrgTree',
                hiddenInputId: 'addExternalUnitId',
                hiddenNameId: 'addExternalUnitName',
                rootCode: '00001'
            });
        }
        // تهيئة عند فتح الـ Modal
        document.getElementById('addSubObjectiveModal')?.addEventListener('shown.bs.modal', function() {
            if (!document.querySelector('#addSubOrgTree .otp-trigger')) initAddSubOrgTree();
        });

        // تأكيد الحذف
        function confirmDelete(type, id, name) {
            document.getElementById('deleteName').textContent = name;
            document.getElementById('deleteForm').action = '/StrategicPlanning/Delete' + type + '/' + id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}

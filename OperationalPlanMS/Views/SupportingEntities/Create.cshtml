@model OperationalPlanMS.Models.ViewModels.SupportingEntityFormViewModel
@{
    ViewData["Title"] = "إضافة جهة مساندة";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">إضافة جهة مساندة جديدة</h4>
        <p class="text-muted mb-0">أدخل بيانات الجهة المساندة</p>
    </div>
    <a href="/SupportingEntities" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <div class="alert alert-info mb-3">
                    <i class="bi bi-info-circle me-2"></i>
                    سيتم إنشاء الكود تلقائياً عند الحفظ
                </div>

                <form asp-controller="SupportingEntities" asp-action="Create" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NameAr" class="form-label">الاسم بالعربية <span class="text-danger">*</span></label>
                            <input asp-for="NameAr" class="form-control" placeholder="اسم الجهة بالعربية" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NameEn" class="form-label">الاسم بالإنجليزية <span class="text-danger">*</span></label>
                            <input asp-for="NameEn" class="form-control" dir="ltr" placeholder="Entity name in English" />
                            <span asp-validation-for="NameEn" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label">نشط</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-end gap-2">
                        <a href="/SupportingEntities" class="btn btn-secondary">إلغاء</a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-2"></i>حفظ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
